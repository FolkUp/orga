# ORGA Security Configuration Template
# КУПЕР Banking-Level Environment Variables

# Security Headers Configuration
CSP_REPORT_URI=https://orga.folkup.app/csp-report
SECURITY_HEADERS_ENABLED=true

# Investigation Platform Security
EVIDENCE_ENCRYPTION_KEY=your-32-byte-encryption-key-here
SOURCE_PROTECTION_ENABLED=true

# Development Security
NODE_ENV=production
ASTRO_TELEMETRY_DISABLED=1

# Multimedia Security Policies
ALLOWED_MEDIA_DOMAINS=orga.folkup.app,static.folkup.app
MAX_UPLOAD_SIZE=50MB
CONTENT_VALIDATION_STRICT=true