# ORGA Phase 3B Environment Configuration
# Copy to .env and configure for your deployment environment

# API Security Configuration
ORGA_API_SECRET=your-jwt-secret-key-here-change-in-production
NODE_ENV=development

# Ecosystem Integration
ADDITIONAL_ORIGINS=https://staging.folkup.app,https://dev.folkup.app

# Database Configuration (Future Phase 3C)
# DATABASE_URL=your-database-connection-string
# REDIS_URL=your-redis-connection-string

# Monitoring and Analytics (Future)
# ANALYTICS_ID=your-analytics-id
# ERROR_TRACKING_DSN=your-error-tracking-dsn

# Phase 3B Feature Flags
ENABLE_ECOSYSTEM_API=true
ENABLE_METADATA_SHARING=true
ENABLE_CROSS_PROJECT_AUTH=true

# Rate Limiting Configuration
API_RATE_LIMIT_DEFAULT=100
API_RATE_LIMIT_ECOSYSTEM=1000
API_RATE_LIMIT_ADMIN=10000

# Security Headers
CSP_REPORT_URI=https://underground.folkup.life/api/csp-report
HSTS_MAX_AGE=31536000

# Build Configuration
BUILD_PHASE=3B
ECOSYSTEM_VERSION=3B.0.0