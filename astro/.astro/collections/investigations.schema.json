{
  "$ref": "#/definitions/investigations",
  "definitions": {
    "investigations": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "lastmod": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "investigation_type": {
          "type": "string",
          "enum": [
            "cultural_analysis",
            "institutional",
            "biographical",
            "media"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "partially_verified",
            "unverified",
            "draft"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_count": {
          "type": "number"
        },
        "timeline_span": {
          "type": "string"
        },
        "featured_image": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "date": {
                "type": "string"
              },
              "archive_url": {
                "type": "string",
                "format": "uri"
              },
              "type": {
                "type": "string",
                "enum": [
                  "primary",
                  "secondary",
                  "media",
                  "academic",
                  "government"
                ]
              }
            },
            "required": [
              "title"
            ],
            "additionalProperties": false
          }
        },
        "pii_reviewed": {
          "type": "boolean"
        },
        "pii_reviewed_by": {
          "type": "string"
        },
        "pii_review_date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "naming_justified": {
          "type": "boolean"
        },
        "legal_risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "legal_approved_by": {
          "type": "string"
        },
        "reviewed_by": {
          "type": "string"
        },
        "review_date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "en"
          ]
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date",
        "investigation_type",
        "status",
        "confidence",
        "tags"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}