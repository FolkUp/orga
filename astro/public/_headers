# Phase 3B Security Headers - Banking-Level Protection
# ORGA Underground Academia - Production deployment
# Enhanced CSP with ecosystem integration support
# Last updated: 2026-05-05 (Phase 3B implementation)

/*
  Content-Security-Policy: default-src 'self'; frame-src https://open.spotify.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://docs.folkup.app https://folkup.app; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-API-Version: 3B.0.0
  X-Ecosystem-Projects: ORGA,DECL,DOCS,AGIL,DSHB

# API Routes - Enhanced security for ecosystem integration
/api/*
  Content-Security-Policy: default-src 'none'; connect-src 'self' https://docs.folkup.app https://folkup.app; frame-ancestors 'none';
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Authorization, Content-Type, X-Ecosystem-Project
  Access-Control-Max-Age: 86400
  X-API-Security-Level: banking-grade

# Static assets — long cache, immutable (Astro hashes filenames in _assets/)
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/javascript; charset=utf-8

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

# HTML pages — short cache, allow Cloudflare revalidation
/*.html
  Cache-Control: public, max-age=3600, must-revalidate
  Vary: Accept-Encoding, Accept-Language

# Sitemap + robots — let crawlers refetch hourly
/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-0.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

# Security disclosure contact
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
