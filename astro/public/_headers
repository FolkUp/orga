# ORGA Security Headers — Banking-Level CSP Implementation
# КУПЕР Static Site Security Configuration for Netlify/Cloudflare

/*
  # Content Security Policy — Multimedia Investigation Platform
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' https:; font-src 'self' data:; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'deny'; object-src 'none'; upgrade-insecure-requests

  # Transport Layer Security
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Anti-Clickjacking Protection
  X-Frame-Options: DENY

  # Content Type Validation
  X-Content-Type-Options: nosniff

  # XSS Protection (Legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Referrer Privacy
  Referrer-Policy: strict-origin-when-cross-origin

  # Feature Policy Restrictions
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # Investigation Platform Security
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # Cache Security
  Cache-Control: public, max-age=31536000, immutable