---
import CookieConsent from '../components/CookieConsent.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import '../styles/accessibility-mobile.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  /**
   * Sibling translations of the current page. Empty for single-language pages.
   * Self is NOT included here — BaseLayout adds the self-referencing hreflang
   * internally. Only pass entries with status === "done".
   */
  alternates?: Array<{ lang: 'ru' | 'en' | 'pt'; href: string }>;
  /**
   * Social-share image (OG / Twitter Card). /public-relative path or absolute URL.
   * Resolved to absolute via Astro.site for scrapers. Falls back to site-wide
   * branded default when omitted.
   */
  image?: string;
  imageAlt?: string;
}

const DEFAULT_OG_IMAGE = '/og/default.jpg';

const {
  title,
  description = "Андерграунд Академия — Исследования андерграундной культуры",
  lang = "ru",
  alternates = [],
  image,
  imageAlt,
} = Astro.props;

// Навигационные элементы с переводом
const navItems = {
  ru: [
    { href: "/investigations/", label: "Расследования" },
    { href: "/longform/", label: "Лонгриды" },
    { href: "/about/", label: "О проекте" },
  ],
  en: [
    { href: "/en/investigations/", label: "Investigations" },
    { href: "/en/longform/", label: "Longform" },
    { href: "/en/about/", label: "About" },
  ],
};

const currentNavItems = navItems[lang as keyof typeof navItems] || navItems.ru;

const consentLang: 'ru' | 'en' | 'pt' =
  lang === 'ru' || lang === 'pt' ? lang : 'en';

const toAbsolute = (path: string): string =>
  Astro.site ? new URL(path, Astro.site).href : path;

const canonicalHref = toAbsolute(Astro.url.pathname);

// hreflang cluster: emit only when we actually have translations. Includes
// self-referencing link (Google requires bidirectional for the cluster to be
// recognized). x-default = English when available, otherwise current locale.
const hreflangEntries = alternates.length > 0
  ? [
      ...alternates.map((a) => ({ lang: a.lang, href: toAbsolute(a.href) })),
      { lang, href: canonicalHref },
    ]
  : [];

// RU-primary policy: x-default points to the Russian sibling when available,
// otherwise falls back to the current page. Decision 2026-04-20 (Андрей).
const xDefaultHref =
  hreflangEntries.find((h) => h.lang === 'ru')?.href ?? canonicalHref;

// OG image resolution — absolute URL needed by social scrapers (FB/Twitter/Telegram
// won't follow relative paths). Branded default ensures twitter:card="summary_large_image"
// declaration always has a valid image (otherwise scrapers fall back to plain link).
const ogImageAbsolute = toAbsolute(image ?? DEFAULT_OG_IMAGE);
const ogImageAltFinal = imageAlt ?? title;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Brand Guide v2.5 Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

    <title>{title}</title>

    <link rel="canonical" href={canonicalHref} />
    {
      hreflangEntries.length > 0 && (
        <>
          {hreflangEntries.map((h) => (
            <link rel="alternate" hreflang={h.lang} href={h.href} />
          ))}
          <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
        </>
      )
    }

    <!-- Meta tags for Underground Academia branding -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltFinal} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={ogImageAltFinal} />

    <!-- Brand colors and theme -->
    <meta name="theme-color" content="#7D4450" />

    <!--
      Phase 3B CSP Migration: Primary CSP now enforced via HTTP headers (_headers file).
      This meta tag serves as fallback for local development and CDN scenarios
      where headers might be stripped. Enhanced connect-src for ecosystem integration.
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; frame-src https://open.spotify.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://docs.folkup.app https://folkup.app; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
    />
  </head>

  <body>
    <!-- Skip link for accessibility — MUST be the first focusable element inside <body> -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="site-container">
      <header class="site-header">
        <nav class="main-nav" role="navigation" aria-label="Main navigation">
          <div class="nav-brand">
            <a href={lang === 'ru' ? "/" : "/en/"} aria-label={lang === 'ru' ? "FolkUp Андерграунд Академия главная" : "FolkUp Underground Academia homepage"} class="brand-link">
              <img src="/folkup-logo.png" alt="FolkUp" class="folkup-logo" />
              <div class="brand-text">
                <span class="brand-title">{lang === 'ru' ? 'Андерграунд Академия' : 'Underground Academia'}</span>
                <span class="brand-subtitle">{lang === 'ru' ? 'Исследования культуры' : 'Culture Research'}</span>
              </div>
            </a>
          </div>

          <div class="nav-right">
            <ul class="nav-menu">
              {currentNavItems.map(item => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
            <LanguageSwitcher currentLang={lang as 'ru' | 'en'} alternates={alternates.map(alt => ({
              lang: alt.lang,
              href: alt.href,
              label: alt.lang.toUpperCase()
            }))} />
          </div>
        </nav>
      </header>

      <main class="site-main" id="main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-content">
          <p class="footer-attribution">
            Part of the <a href="https://folkup.app" rel="external">FolkUp</a> ecosystem
          </p>
          <p class="footer-support">
            <a href="https://ko-fi.com/folkup" rel="external" aria-label="Support via Ko-fi">
              Support this research
            </a>
          </p>
          <div class="footer-legal">
            <a href="/legal/privacy-policy/">Privacy Policy</a>
            <a href="/legal/terms-of-use/">Terms of Use</a>
            <a href="/legal/cookie-policy/">Cookie Policy</a>
          </div>
        </div>
      </footer>
    </div>

    <CookieConsent lang={consentLang} />
  </body>
</html>

<style>
  /* CSS Reset and base styles */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* CSS Custom Properties - Brand Guide v2.5 Palette D */
  :root {
    /* Colors - FolkUp Brand Guide v2.5 Palette D */
    --color-bordeaux: #7D4450;          /* Primary dark - Bordeaux */
    --color-sage: #839E75;              /* Secondary green - Sage */
    --color-amber: #E8AD4A;             /* Accent warm - Amber */
    --color-ivory: #FEFCF6;             /* Background light - Ivory */
    --color-text-primary: #2D3748;      /* Text dark */
    --color-text-inverse: #FEFCF6;      /* Text light - Ivory */

    /* Typography - Brand Guide v2.5 Font Stack */
    --font-display: 'Playfair Display', Georgia, serif;    /* Headings */
    --font-body: 'Source Sans 3', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;    /* Body text */
    --font-logo: 'Pacifico', cursive;                      /* Logo/display */
    --font-size-base: 1rem;
    --line-height-body: 1.6;
    --line-height-heading: 1.2;

    /* Spacing */
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;

    /* Layout */
    --container-max-width: 75rem;
    --container-padding: var(--space-md);
  }

  /* Base typography */
  html {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    line-height: var(--line-height-body);
    color: var(--color-text-primary);
    background-color: var(--color-ivory);
  }

  /* Layout */
  .site-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-main {
    flex: 1;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--container-padding);
    width: 100%;
  }

  /* Header */
  .site-header {
    background-color: var(--color-bordeaux);
    color: var(--color-text-inverse);
    padding: var(--space-md) var(--container-padding);
  }

  .main-nav {
    max-width: var(--container-max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .brand-link {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .folkup-logo {
    height: 32px;
    width: auto;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: var(--line-height-heading);
  }

  .brand-subtitle {
    font-size: 0.875rem;
    opacity: 0.9;
    font-weight: 400;
  }

  .nav-menu {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .nav-menu a {
    color: inherit;
    text-decoration: none;
    font-weight: 500;
    padding: var(--space-sm) var(--space-md);
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .nav-menu a:hover,
  .nav-menu a:focus {
    background-color: rgba(255, 255, 255, 0.1);
    outline: 2px solid transparent;
  }

  /* Footer */
  .site-footer {
    background-color: var(--color-bordeaux);
    color: var(--color-text-inverse);
    padding: var(--space-lg) var(--container-padding);
    margin-top: var(--space-2xl);
  }

  .footer-content {
    max-width: var(--container-max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: 0.875rem;
  }

  .footer-content a {
    color: var(--color-sage);
    text-decoration: none;
  }

  .footer-content a:hover,
  .footer-content a:focus {
    text-decoration: underline;
  }

  /* Accessibility */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: var(--color-bordeaux);
    color: var(--color-text-inverse);
    padding: 8px;
    text-decoration: none;
    border-radius: 0 0 4px 0;
    z-index: 1000;
  }

  .skip-link:focus {
    top: 6px;
  }

  /* Focus management */
  :focus-visible {
    outline: 2px solid var(--color-amber);
    outline-offset: 2px;
  }

  /* Responsive typography and layout */
  @media (min-width: 48rem) {
    .folkup-logo {
      height: 40px;
    }

    .brand-title {
      font-size: 1.75rem;
    }

    .brand-subtitle {
      font-size: 1rem;
    }
  }

  @media (max-width: 47.9rem) {
    .folkup-logo {
      height: 24px;
    }

    .brand-link {
      gap: var(--space-sm);
    }

    .nav-right {
      gap: var(--space-md);
    }

    .nav-menu {
      gap: var(--space-md);
    }
  }

  /* Responsive Tables - ECOSYSTEM pattern from retro-tech */
  table {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
  }

  table th,
  table td {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    border: 1px solid rgba(45, 55, 72, 0.2);
    word-wrap: break-word;
    hyphens: auto;
  }

  table th {
    background-color: rgba(125, 68, 80, 0.05);
    font-weight: 600;
    color: var(--color-bordeaux);
  }

  /* Mobile table optimizations */
  @media (max-width: 47.9rem) {
    table {
      font-size: 0.875rem;
    }

    table th,
    table td {
      padding: var(--space-xs) var(--space-sm);
      min-width: 120px; /* Prevents columns from becoming too narrow */
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>