---
import { getCollection, type CollectionEntry } from 'astro:content';
import PremiumLongformLayout from '../../layouts/PremiumLongformLayout.astro';

type Alternate = { lang: 'ru' | 'en' | 'pt'; href: string };

export async function getStaticPaths() {
  const entries = await getCollection('longform');
  const slugToEntry = new Map(entries.map((e) => [e.slug, e]));

  return entries.map((entry) => {
    const translations = entry.data.translations ?? {};
    const alternates: Alternate[] = Object.entries(translations)
      .filter(([lang]) => lang !== entry.data.language)
      .filter(([, meta]) => meta.status === 'done')
      .filter(([, meta]) => meta.slug && slugToEntry.has(meta.slug))
      .map(([lang, meta]) => ({
        lang: lang as Alternate['lang'],
        href: `/longform/${meta.slug}/`,
      }));

    return {
      params: { slug: entry.slug },
      props: { entry, alternates },
    };
  });
}

interface Props {
  entry: CollectionEntry<'longform'>;
  alternates: Alternate[];
}

const { entry, alternates } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
---

<PremiumLongformLayout
  title={data.title}
  subtitle={data.subtitle}
  byline={data.byline}
  bylineNote={data.byline_note}
  date={data.date}
  lastmod={data.lastmod}
  language={data.language}
  wordCount={data.word_count}
  subjectArtist={data.subject_artist}
  subjectWork={data.subject_work}
  tags={data.tags}
  description={data.description}
  audioEmbed={data.audio_embed && {
    primary: data.audio_embed.primary,
    spotifyTrackId: data.audio_embed.spotify_track_id,
    youtubeVideoId: data.audio_embed.youtube_video_id,
    platforms: data.audio_embed.platforms,
    consentRequired: data.audio_embed.consent_required,
  }}
  alternates={alternates}
  ogImage={data.og_image}
  ogImageAlt={data.og_image_alt}
>
  <Content />
</PremiumLongformLayout>
