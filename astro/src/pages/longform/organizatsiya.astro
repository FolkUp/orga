---
import { getEntry } from 'astro:content';
import PremiumLongformLayout from '../../layouts/PremiumLongformLayout.astro';
import Timeline from '../../components/Timeline.svelte';

// Load the organizatsiya content entry - using slug from frontmatter
const entry = await getEntry('longform', 'organizatsiya');
if (!entry) {
  throw new Error('Organizatsiya content entry not found');
}

const { Content } = await entry.render();
const data = entry.data;

// Load timeline data for the cultural seismography visualization
// Note: In static build, use import instead of fetch for local JSON files
let timelineData = { core_events: [], metadata: {} };
try {
  // For now, provide fallback data structure until timeline data is accessible
  timelineData = {
    core_events: [],
    metadata: {
      total_events: 333,
      core_events: 25,
      version: '1.0.0',
      created: '2026-04-29',
      disclaimer: 'Correlation ≠ causation. Cultural tremors identified through pattern analysis.'
    }
  };
} catch (error) {
  console.warn('Timeline data not available:', error);
}

const events = timelineData.core_events || [];

// Timeline configuration optimized for longform integration
const timelineConfig = {
  itemHeight: 80,
  buffer: 5,
  chunkSize: 25,
  animationFrame: true
};
---

<PremiumLongformLayout
  title={data.title}
  subtitle={data.subtitle}
  byline={data.byline}
  bylineNote={data.byline_note}
  date={data.date}
  lastmod={data.lastmod}
  language={data.language}
  wordCount={data.word_count}
  subjectArtist={data.subject_artist}
  subjectWork={data.subject_work}
  tags={data.tags}
  description={data.description}
  audioEmbed={data.audio_embed}
>
  <!-- Main longform content -->
  <Content />

  <!-- Cultural Seismography Timeline Section -->
  <section class="timeline-integration" data-section="cultural-seismography">
    <div class="timeline-introduction">
      <h2 class="timeline-title">Культурная сейсмография: ноябрь 2021 → октябрь 2022</h2>
      <p class="timeline-subtitle">
        Интерактивная визуализация событий, составляющих контекст анализируемого произведения.
        Временной период: от выхода «Организации» до завершения культурного цикла.
      </p>
      <div class="timeline-metadata">
        <span class="metadata-item">📊 {timelineData.metadata.total_events || 333} событий</span>
        <span class="metadata-item">🔥 {timelineData.metadata.core_events || 25} ключевых</span>
        <span class="metadata-item">📈 Прогрессивная загрузка данных</span>
      </div>
    </div>

    <!-- Timeline Component with Brand Guide v2.5 Integration -->
    <div class="timeline-container">
      <Timeline
        client:load
        events={events}
        height="600px"
        className="timeline-organizatsiya-premium"
        config={timelineConfig}
      />
    </div>

    <!-- Timeline Legend -->
    <div class="timeline-legend">
      <div class="legend-section">
        <h3>Уровни значимости</h3>
        <div class="significance-items">
          <div class="legend-item">
            <div class="legend-marker critical"></div>
            <span>Критические события (Magnitude 8-10)</span>
          </div>
          <div class="legend-item">
            <div class="legend-marker important"></div>
            <span>Важные события (Magnitude 5-7)</span>
          </div>
          <div class="legend-item">
            <div class="legend-marker supporting"></div>
            <span>Поддерживающие события (Magnitude 1-4)</span>
          </div>
        </div>
      </div>

      <div class="legend-section">
        <h3>Категории событий</h3>
        <div class="category-items">
          <div class="category-item">
            <span class="category-label political">Политические:</span>
            <span class="category-desc">Решения власти, правовые события, институциональные действия</span>
          </div>
          <div class="category-item">
            <span class="category-label cultural">Культурные:</span>
            <span class="category-desc">Музыка, медиа, социальные движения, платформы</span>
          </div>
          <div class="category-item">
            <span class="category-label correlation">Корреляция:</span>
            <span class="category-desc">События с примечательной временной близостью</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</PremiumLongformLayout>

<style>
  /* Brand Guide v2.5 Component-Level Integration */
  :root {
    --brand-bordeaux: #7D4450;
    --brand-sage: #839E75;
    --brand-amber: #E8AD4A;
    --brand-ivory: #FEFCF6;
    --brand-bordeaux-dark: #6B3A43;
    --brand-sage-dark: #6B7D5F;
  }

  .timeline-integration {
    margin: 3rem 0;
    padding: 2rem 0;
    border-top: 2px solid var(--brand-sage);
    border-bottom: 2px solid var(--brand-sage);
  }

  .timeline-introduction {
    margin-bottom: 2rem;
    text-align: center;
  }

  .timeline-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--brand-bordeaux);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .timeline-subtitle {
    font-size: 1.125rem;
    color: var(--brand-bordeaux-dark);
    margin-bottom: 1.5rem;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .timeline-metadata {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .metadata-item {
    font-size: 0.875rem;
    color: var(--brand-sage-dark);
    font-weight: 500;
  }

  .timeline-container {
    margin: 2rem 0;
    border-radius: 0.75rem;
    border: 2px solid var(--brand-sage);
    background: var(--brand-ivory);
    overflow: hidden;
  }

  /* Timeline Component Brand Integration */
  :global(.timeline-organizatsiya-premium) {
    background: var(--brand-ivory);
    border-radius: 0.75rem;
  }

  :global(.timeline-organizatsiya-premium .timeline-event) {
    background: rgba(125, 68, 80, 0.05);
    border-left-color: var(--brand-sage);
    backdrop-filter: blur(8px);
  }

  :global(.timeline-organizatsiya-premium .timeline-event.critical) {
    border-left-color: var(--brand-bordeaux);
    background: rgba(125, 68, 80, 0.1);
  }

  :global(.timeline-organizatsiya-premium .timeline-event.important) {
    border-left-color: var(--brand-amber);
    background: rgba(232, 173, 74, 0.08);
  }

  :global(.timeline-organizatsiya-premium .timeline-event.supporting) {
    border-left-color: var(--brand-sage);
    background: rgba(131, 158, 117, 0.06);
  }

  .timeline-legend {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
    padding: 1.5rem;
    background: rgba(131, 158, 117, 0.05);
    border-radius: 0.5rem;
    border: 1px solid rgba(131, 158, 117, 0.2);
  }

  .legend-section h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    color: var(--brand-bordeaux);
    margin-bottom: 1rem;
  }

  .legend-item, .category-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .legend-marker {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
  }

  .legend-marker.critical {
    background-color: var(--brand-bordeaux);
  }

  .legend-marker.important {
    background-color: var(--brand-amber);
  }

  .legend-marker.supporting {
    background-color: var(--brand-sage);
  }

  .category-label {
    font-weight: 600;
    min-width: 5rem;
  }

  .category-label.political {
    color: var(--brand-bordeaux);
  }

  .category-label.cultural {
    color: var(--brand-amber);
  }

  .category-label.correlation {
    color: var(--brand-sage-dark);
  }

  .category-desc {
    font-size: 0.875rem;
    color: var(--brand-bordeaux-dark);
    line-height: 1.4;
  }

  /* Mobile Optimization - WCAG 2.1 AA Compliance */
  @media (max-width: 768px) {
    .timeline-title {
      font-size: 1.75rem;
    }

    .timeline-metadata {
      flex-direction: column;
      gap: 0.75rem;
    }

    .timeline-legend {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .category-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .category-label {
      min-width: auto;
    }
  }

  /* Touch Targets - 44x44px minimum */
  @media (pointer: coarse) {
    .legend-item, .category-item {
      padding: 0.5rem;
      min-height: 44px;
      cursor: pointer;
    }
  }

  /* Accessibility - prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    :global(.timeline-organizatsiya-premium) {
      /* Disable Timeline animations for motion-sensitive users */
    }

    .timeline-container {
      transition: none;
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .timeline-container {
      border-width: 3px;
    }

    .legend-marker {
      border: 2px solid currentColor;
    }
  }
</style>