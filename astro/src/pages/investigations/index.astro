---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConfidenceBadge from '../../components/ConfidenceBadge.astro';

// Fetch all published investigations
const investigations = await getCollection('investigations', ({ data }) => {
  return data.draft !== true;
});

// Sort by date (newest first)
const sortedInvestigations = investigations.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Investigation type labels
const typeLabels: Record<string, string> = {
  cultural_analysis: 'Cultural Analysis',
  institutional: 'Institutional',
  biographical: 'Biographical',
  media: 'Media Analysis'
};

// Format date
function formatDate(d: Date): string {
  return d.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<BaseLayout title="Investigations — Underground Academia" description="Research investigations into cultural phenomena through rigorous academic methodology.">
  <section class="investigations-index">
    <header class="investigations-index__header">
      <h1 class="investigations-index__title">Investigations</h1>
      <p class="investigations-index__description">
        Research into cultural phenomena through systematic evidence collection
        and multi-source verification. Each investigation follows the Underground Academia
        methodology of cultural seismography.
      </p>
    </header>

    {sortedInvestigations.length > 0 ? (
      <ol class="investigations-list">
        {sortedInvestigations.map((investigation) => (
          <li class="investigation-card">
            <article>
              <header class="investigation-card__header">
                <div class="investigation-card__meta">
                  <span class="investigation-card__type">
                    {typeLabels[investigation.data.investigation_type] || investigation.data.investigation_type}
                  </span>
                  <ConfidenceBadge status={investigation.data.status} />
                </div>

                <h2 class="investigation-card__title">
                  <a href={`/investigations/${investigation.slug}/`}>
                    {investigation.data.title}
                  </a>
                </h2>
              </header>

              {investigation.data.description && (
                <p class="investigation-card__description">
                  {investigation.data.description}
                </p>
              )}

              <footer class="investigation-card__footer">
                <time class="investigation-card__date" datetime={investigation.data.date.toISOString()}>
                  {formatDate(investigation.data.date)}
                </time>

                {investigation.data.evidence_count !== undefined && (
                  <span class="investigation-card__evidence">
                    {investigation.data.evidence_count} evidence items
                  </span>
                )}

                {investigation.data.tags && investigation.data.tags.length > 0 && (
                  <ul class="investigation-card__tags">
                    {investigation.data.tags.slice(0, 4).map((tag) => (
                      <li class="investigation-card__tag">{tag}</li>
                    ))}
                  </ul>
                )}
              </footer>
            </article>
          </li>
        ))}
      </ol>
    ) : (
      <div class="investigations-empty">
        <p>No investigations published yet. Research is in progress.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .investigations-index {
    max-width: 55rem;
    margin: 0 auto;
  }

  .investigations-index__header {
    text-align: center;
    padding: var(--space-2xl) 0;
    margin-bottom: var(--space-2xl);
    border-bottom: 2px solid var(--color-bordeaux);
  }

  .investigations-index__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-bordeaux);
    margin: 0 0 var(--space-md) 0;
    line-height: 1.2;
  }

  .investigations-index__description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #4A5568;
    max-width: 40rem;
    margin: 0 auto;
  }

  .investigations-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .investigation-card {
    background: white;
    border: 1px solid rgba(26, 54, 93, 0.15);
    border-left: 4px solid var(--color-bordeaux);
    border-radius: 0 var(--space-sm) var(--space-sm) 0;
    padding: var(--space-lg);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .investigation-card:hover {
    box-shadow: 0 4px 16px rgba(26, 54, 93, 0.12);
    border-left-color: var(--color-amber);
  }

  .investigation-card__header {
    margin-bottom: var(--space-md);
  }

  .investigation-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .investigation-card__type {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-bordeaux);
    background-color: rgba(26, 54, 93, 0.08);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--space-xs);
  }

  .investigation-card__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .investigation-card__title a {
    color: var(--color-bordeaux);
    text-decoration: none;
  }

  .investigation-card__title a:hover,
  .investigation-card__title a:focus {
    color: var(--color-amber);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .investigation-card__description {
    font-size: 1rem;
    line-height: var(--line-height-body);
    color: #4A5568;
    margin: 0 0 var(--space-md) 0;
  }

  .investigation-card__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    font-size: 0.875rem;
    color: rgba(45, 55, 72, 0.7);
  }

  .investigation-card__evidence::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-amber);
    margin-right: var(--space-xs);
  }

  .investigation-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .investigation-card__tag {
    font-size: 0.6875rem;
    padding: 2px var(--space-sm);
    border: 1px solid rgba(26, 54, 93, 0.15);
    border-radius: var(--space-xs);
    color: var(--color-bordeaux);
  }

  .investigations-empty {
    text-align: center;
    padding: var(--space-2xl);
    color: rgba(45, 55, 72, 0.6);
    font-size: 1.125rem;
  }

  /* Responsive */
  @media (max-width: 48rem) {
    .investigations-index__title {
      font-size: 2rem;
    }

    .investigation-card__title {
      font-size: 1.25rem;
    }

    .investigation-card__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }
</style>
