---
import BaseLayout from '@layouts/BaseLayout.astro';
import AudioStoryPlayer from '@components/AudioStoryPlayer.astro';
import EvidenceGallery from '@components/EvidenceGallery.astro';
import Icon from '@components/Icon.astro';
import PullQuote from '@components/PullQuote.astro';
---

<BaseLayout title="ORGA — Underground Academia Research Institute">
  <!-- HERO SECTION: Investigation Platform -->
  <section class="hero-platform">
    <div class="hero-grid">
      <div class="manifesto-block">
        <div class="institution-mark">
          <span class="designation">ОРГА</span>
          <span class="subtitle">RESEARCH INSTITUTE</span>
        </div>

        <h1 class="platform-title">
          CULTURAL INVESTIGATIONS
          <span class="emphasis-platform">PLATFORM</span>
        </h1>

        <div class="methodology-statement">
          <p class="approach-description">
            Multimedia investigation framework for cultural phenomena analysis.
            <strong>Banking-level verification standards</strong> applied to
            cultural intelligence research.
          </p>

          <div class="research-credentials">
            <span class="credential-item">OSINT METHODOLOGY</span>
            <span class="credential-item">MULTIMEDIA LONGREADS</span>
            <span class="credential-item">OPEN INVESTIGATION FRAMEWORK</span>
          </div>
        </div>

        <div class="platform-status">
          <div class="status-metric ready">
            <span class="metric-number">∞</span>
            <span class="metric-label">Investigation Capacity</span>
            <span class="metric-detail">Replicable Framework</span>
          </div>
          <div class="status-metric ready">
            <span class="metric-number">3</span>
            <span class="metric-label">Language Support</span>
            <span class="metric-detail">RU/PT/EN Multilingual</span>
          </div>
          <div class="status-metric verified">
            <span class="metric-status">READY</span>
            <span class="metric-label">Platform Launch</span>
            <span class="metric-detail">Investigation framework deployed</span>
          </div>
        </div>
      </div>

      <div class="platform-visualization">
        <div class="investigation-framework">
          <div class="framework-layers">
            <div class="layer-element" style="--layer-depth: 1; --opacity: 0.9;">Investigation Layer</div>
            <div class="layer-element" style="--layer-depth: 2; --opacity: 0.7;">Evidence Layer</div>
            <div class="layer-element" style="--layer-depth: 3; --opacity: 0.5;">Source Layer</div>
            <div class="layer-element" style="--layer-depth: 4; --opacity: 0.3;">Verification Layer</div>
          </div>
          <div class="framework-label">INVESTIGATION FRAMEWORK</div>
        </div>

        <div class="grid-overlay"></div>
      </div>
    </div>
  </section>

  <!-- INVESTIGATION FRAMEWORK: Evidence Gallery Integration -->
  <section class="investigation-framework-section">
    <div class="section-header">
      <h2 class="framework-title">INVESTIGATION FRAMEWORK</h2>
      <p class="framework-description">
        Multi-layered methodology for cultural phenomena investigation.
        Replicable framework for banking-level verification standards.
      </p>
    </div>

    <div class="methodology-container">
      <div class="framework-steps">
        <div class="step-marker">
          <span class="step-level">PHASE 1</span>
          <span class="step-description">Data Collection</span>
        </div>
        <div class="step-marker">
          <span class="step-level">PHASE 2</span>
          <span class="step-description">Source Verification</span>
        </div>
        <div class="step-marker">
          <span class="step-level">PHASE 3</span>
          <span class="step-description">Analysis & Documentation</span>
        </div>
      </div>

      <EvidenceGallery
        title="Investigation Framework Components"
        description="Multimedia framework for cultural investigation methodology"
        evidence={[
          {
            id: "fw-001",
            type: "document",
            title: "OSINT Methodology Guide",
            description: "Open-source intelligence collection framework",
            url: "/framework/osint-methodology.pdf",
            metadata: {
              source: "ORGA Research Team",
              date: "2026-04-13",
              significance: "high",
              verification: "verified"
            },
            tags: ["methodology", "osint", "framework"]
          },
          {
            id: "fw-002",
            type: "template",
            title: "Investigation Template",
            description: "Replicable template for cultural investigations",
            url: "/framework/investigation-template.md",
            metadata: {
              source: "Platform Development",
              date: "2026-04-13",
              significance: "high",
              verification: "verified"
            },
            tags: ["template", "framework", "investigation"]
          },
          {
            id: "fw-003",
            type: "guide",
            title: "Verification Standards",
            description: "Banking-level verification protocols",
            url: "/framework/verification-standards.pdf",
            metadata: {
              source: "Quality Assurance",
              date: "2026-04-13",
              significance: "critical",
              verification: "verified"
            },
            tags: ["verification", "standards", "quality"]
          }
        ]}
        layout="masonry"
        allowAnnotations={true}
        showMetadata={true}
        class="framework-gallery"
      />
    </div>
  </section>

  <!-- MULTIMEDIA INVESTIGATIONS: Audio Framework Demo -->
  <section class="multimedia-investigations">
    <div class="investigation-header">
      <div class="framework-indicator">
        <div class="status-lights">
          <div class="status-light"></div>
          <div class="status-light"></div>
          <div class="status-light"></div>
          <div class="status-light active"></div>
        </div>
        <span class="framework-version">FRAMEWORK v2.0</span>
      </div>

      <h2 class="investigation-title">MULTIMEDIA FRAMEWORK</h2>
      <p class="investigation-description">
        Interactive audio-visual investigation methodology demo.
        Banking-level verification standards applied to multimedia storytelling.
      </p>
    </div>

    <AudioStoryPlayer
      title="Platform Methodology: Investigation Framework"
      duration="28:45"
      audioSrc="/audio/framework/methodology-guide.mp3"
      transcript={[
        {
          start: 0,
          end: 30,
          speaker: "Framework Guide",
          text: "Welcome to the ORGA Investigation Platform. This framework provides replicable methodology for cultural phenomena research.",
          chapter: "Platform Overview"
        },
        {
          start: 30,
          end: 120,
          speaker: "Methodology Expert",
          text: "Our platform combines OSINT techniques with multimedia storytelling, enabling investigators to create compelling, verified narratives.",
          chapter: "Methodology",
          evidence: [
            {
              type: "document",
              title: "OSINT Framework Guide",
              url: "/framework/osint-methodology.pdf",
              description: "Open-source intelligence collection protocols"
            }
          ]
        },
        {
          start: 120,
          end: 240,
          speaker: "Platform Developer",
          text: "The framework supports multiple investigation types, from cultural analysis to social phenomenon research, with banking-level verification standards.",
          chapter: "Platform Capabilities"
        }
      ]}
      chapters={[
        {
          title: "Platform Overview",
          timestamp: 0,
          description: "ORGA investigation platform introduction"
        },
        {
          title: "Framework Methodology",
          timestamp: 30,
          description: "Banking-level verification and multimedia integration"
        },
        {
          title: "Platform Capabilities",
          timestamp: 120,
          description: "Investigation types and framework flexibility"
        },
        {
          title: "Implementation Guide",
          timestamp: 240,
          description: "Getting started with investigation framework"
        }
      ]}
      class="framework-player"
    />

    <div class="framework-metadata">
      <div class="metadata-grid">
        <div class="meta-item">
          <span class="meta-label">FRAMEWORK VERSION</span>
          <span class="meta-value">v2.0.0</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">VERIFICATION</span>
          <span class="meta-value">BANKING-LEVEL</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">DEPLOYMENT</span>
          <span class="meta-value">PRODUCTION READY</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">LICENSE</span>
          <span class="meta-value">OPEN FRAMEWORK</span>
        </div>
      </div>
    </div>
  </section>

  <!-- RESEARCH METHODOLOGY DISCLOSURE -->
  <section class="methodology-disclosure">
    <PullQuote
      text="Every investigation begins with the assumption that official narratives are incomplete. Our methodology combines academic rigor with underground verification to construct more complete pictures of social reality."
      attribution="ORGA Research Ethics Statement"
      class="methodology-quote"
    />

    <div class="disclosure-grid">
      <div class="disclosure-panel">
        <h3 class="panel-title">DATA SOURCES</h3>
        <ul class="source-list">
          <li>Open-source intelligence (OSINT)</li>
          <li>Peer-reviewed academic publications</li>
          <li>Underground network verification</li>
          <li>Primary source documentation</li>
        </ul>
      </div>

      <div class="disclosure-panel">
        <h3 class="panel-title">VERIFICATION PROTOCOL</h3>
        <ul class="protocol-list">
          <li>Multi-source triangulation</li>
          <li>Independent fact-checking</li>
          <li>Community validation</li>
          <li>Transparency documentation</li>
        </ul>
      </div>

      <div class="disclosure-panel">
        <h3 class="panel-title">ETHICAL FRAMEWORK</h3>
        <ul class="ethics-list">
          <li>Harm reduction protocols</li>
          <li>Source protection standards</li>
          <li>Privacy preservation</li>
          <li>Academic integrity compliance</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- UNDERGROUND MANIFESTO FOOTER -->
  <footer class="manifesto-footer">
    <div class="manifesto-text">
      <div class="manifesto-statement">
        "In the space between academic towers and street-level reality,
        we conduct research that serves truth rather than power."
      </div>
      <div class="signature">— ORGA Research Collective</div>
    </div>

    <div class="institutional-codes">
      <span class="code-item">REG. №2024-UA-001</span>
      <span class="code-item">ISO 27001:2022</span>
      <span class="code-item">GDPR COMPLIANT</span>
    </div>
  </footer>
</BaseLayout>

<style>
  /* UNDERGROUND ACADEMIA GLOBAL STYLES */
  :root {
    /* Underground Academia color palette */
    --ua-maritime-deep: #0a1728;
    --ua-maritime-medium: #1a365d;
    --ua-amber-warm: #d69e2e;
    --ua-amber-bright: #f6e05e;
    --ua-red-signal: #e53e3e;
    --ua-grey-concrete: #718096;
    --ua-white-paper: #f7fafc;
    --ua-black-ink: #1a202c;

    /* Typography scales */
    --ua-text-xs: 0.75rem;
    --ua-text-sm: 0.875rem;
    --ua-text-base: 1rem;
    --ua-text-lg: 1.125rem;
    --ua-text-xl: 1.25rem;
    --ua-text-2xl: 1.5rem;
    --ua-text-3xl: 1.875rem;
    --ua-text-4xl: 2.25rem;
    --ua-text-hero: clamp(2.5rem, 6vw, 4rem);

    /* Spacing system */
    --ua-space-xs: 0.5rem;
    --ua-space-sm: 1rem;
    --ua-space-md: 1.5rem;
    --ua-space-lg: 2rem;
    --ua-space-xl: 3rem;
    --ua-space-2xl: 4rem;

    /* Industrial effects */
    --ua-noise: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.05'/%3E%3C/svg%3E");
    --ua-grid-pattern: linear-gradient(rgba(215, 158, 46, 0.1) 1px, transparent 1px),
                       linear-gradient(90deg, rgba(215, 158, 46, 0.1) 1px, transparent 1px);
  }

  /* RESET AND BASE STYLES */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: var(--ua-maritime-deep);
    color: var(--ua-white-paper);
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* HERO SECTION: Platform */
  .hero-platform {
    min-height: 100vh;
    background:
      var(--ua-noise),
      linear-gradient(135deg, var(--ua-maritime-deep) 0%, var(--ua-maritime-medium) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--ua-space-2xl);
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--ua-space-2xl);
    min-height: 100vh;
    align-items: center;
  }

  .manifesto-block {
    z-index: 2;
    position: relative;
  }

  .institution-mark {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--ua-space-lg);
    border-left: 4px solid var(--ua-amber-warm);
    padding-left: var(--ua-space-md);
  }

  .designation {
    font-family: 'Staatliches', 'Arial Black', sans-serif;
    font-size: var(--ua-text-3xl);
    color: var(--ua-amber-warm);
    line-height: 0.9;
    letter-spacing: 0.05em;
  }

  .subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--ua-text-sm);
    color: var(--ua-grey-concrete);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  .platform-title {
    font-family: 'Staatliches', 'Arial Black', sans-serif;
    font-size: var(--ua-text-hero);
    line-height: 0.85;
    color: var(--ua-white-paper);
    margin-bottom: var(--ua-space-lg);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .emphasis-platform {
    display: block;
    color: var(--ua-amber-warm);
    position: relative;
    transform: translateX(1rem) rotate(-0.5deg);
    text-shadow: 2px 2px 0 var(--ua-maritime-deep);
  }

  .methodology-statement {
    margin-bottom: var(--ua-space-xl);
    padding: var(--ua-space-md);
    background: rgba(26, 54, 93, 0.7);
    border: 1px solid rgba(215, 158, 46, 0.3);
    backdrop-filter: blur(10px);
  }

  .approach-description {
    font-size: var(--ua-text-lg);
    margin-bottom: var(--ua-space-md);
    line-height: 1.7;
  }

  .research-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ua-space-sm);
  }

  .credential-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--ua-text-xs);
    color: var(--ua-amber-warm);
    background: rgba(215, 158, 46, 0.1);
    padding: 0.25rem 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--ua-amber-warm);
  }

  .investigation-status {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--ua-space-md);
  }

  .status-metric {
    text-align: center;
    padding: var(--ua-space-sm);
    border: 2px solid rgba(215, 158, 46, 0.3);
    background: rgba(10, 23, 40, 0.8);
  }

  .metric-number {
    display: block;
    font-family: 'Staatliches', sans-serif;
    font-size: var(--ua-text-2xl);
    color: var(--ua-amber-warm);
    line-height: 1;
  }

  .metric-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--ua-text-xs);
    color: var(--ua-grey-concrete);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* PLATFORM VISUALIZATION */
  .platform-visualization {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }





  .grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--ua-grid-pattern);
    background-size: 20px 20px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* ARCHAEOLOGICAL LAYERS SECTION */
  .archaeological-layers {
    padding: var(--ua-space-2xl);
    background: var(--ua-maritime-medium);
    position: relative;
  }

  .section-header {
    max-width: 1200px;
    margin: 0 auto var(--ua-space-xl);
    text-align: center;
  }

  .layers-title {
    font-family: 'Staatliches', sans-serif;
    font-size: var(--ua-text-4xl);
    color: var(--ua-amber-warm);
    margin-bottom: var(--ua-space-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .layers-description {
    font-size: var(--ua-text-lg);
    color: var(--ua-grey-concrete);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .stratigraphy-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--ua-space-xl);
    align-items: start;
  }

  .layer-depth-markers {
    position: sticky;
    top: var(--ua-space-xl);
  }

  .depth-marker {
    display: flex;
    flex-direction: column;
    padding: var(--ua-space-md);
    border-left: 3px solid var(--ua-amber-warm);
    margin-bottom: var(--ua-space-lg);
    background: rgba(10, 23, 40, 0.8);
  }

  .depth-level {
    font-family: 'Staatliches', sans-serif;
    font-size: var(--ua-text-sm);
    color: var(--ua-amber-warm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .depth-description {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--ua-text-xs);
    color: var(--ua-grey-concrete);
    margin-top: 0.25rem;
  }

  .evidence-stratigraphy {
    background: rgba(10, 23, 40, 0.5);
    border: 1px solid rgba(215, 158, 46, 0.3);
    border-radius: 0;
  }

  /* UNDERGROUND RADIO SECTION */
  .underground-radio {
    padding: var(--ua-space-2xl);
    background:
      var(--ua-noise),
      linear-gradient(45deg, var(--ua-black-ink) 0%, var(--ua-maritime-deep) 100%);
  }

  .radio-header {
    max-width: 1200px;
    margin: 0 auto var(--ua-space-xl);
    display: flex;
    align-items: center;
    gap: var(--ua-space-lg);
  }

  .broadcast-indicator {
    display: flex;
    align-items: center;
    gap: var(--ua-space-sm);
    padding: var(--ua-space-sm);
    background: rgba(215, 158, 46, 0.1);
    border: 1px solid var(--ua-amber-warm);
  }

  .signal-strength {
    display: flex;
    gap: 2px;
    align-items: end;
  }

  .signal-bar {
    width: 4px;
    height: 8px;
    background: rgba(215, 158, 46, 0.3);
    border-radius: 1px;
  }

  .signal-bar:nth-child(2) { height: 12px; }
  .signal-bar:nth-child(3) { height: 16px; }
  .signal-bar:nth-child(4) { height: 20px; }

  .signal-bar.active {
    background: var(--ua-amber-warm);
    animation: signal-pulse 2s ease-in-out infinite;
  }

  @keyframes signal-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .frequency {
    font-family: 'JetBrains Mono', monospace;
    color: var(--ua-amber-warm);
    font-size: var(--ua-text-sm);
    font-weight: 500;
  }

  .radio-title {
    font-family: 'Staatliches', sans-serif;
    font-size: var(--ua-text-3xl);
    color: var(--ua-white-paper);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .radio-description {
    color: var(--ua-grey-concrete);
    font-size: var(--ua-text-base);
    flex: 1;
  }

  .underground-player {
    max-width: 1200px;
    margin: 0 auto var(--ua-space-lg);
    border: 2px solid var(--ua-amber-warm);
    background: rgba(10, 23, 40, 0.9);
  }

  .transmission-metadata {
    max-width: 1200px;
    margin: 0 auto;
  }

  .metadata-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--ua-space-md);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    padding: var(--ua-space-sm);
    background: rgba(26, 54, 93, 0.7);
    border: 1px solid rgba(215, 158, 46, 0.3);
  }

  .meta-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--ua-text-xs);
    color: var(--ua-amber-warm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }

  .meta-value {
    font-family: 'Inter', sans-serif;
    font-size: var(--ua-text-sm);
    color: var(--ua-white-paper);
    font-weight: 500;
  }

  /* METHODOLOGY DISCLOSURE SECTION */
  .methodology-disclosure {
    padding: var(--ua-space-2xl);
    background: rgba(26, 54, 93, 0.3);
  }

  .methodology-quote {
    max-width: 1000px;
    margin: 0 auto var(--ua-space-xl);
    text-align: center;
    background: rgba(10, 23, 40, 0.8);
    border: 2px solid var(--ua-amber-warm);
    border-left: 8px solid var(--ua-red-signal);
  }

  .disclosure-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--ua-space-lg);
  }

  .disclosure-panel {
    background: rgba(10, 23, 40, 0.9);
    border: 1px solid rgba(215, 158, 46, 0.3);
    padding: var(--ua-space-lg);
  }

  .panel-title {
    font-family: 'Staatliches', sans-serif;
    font-size: var(--ua-text-xl);
    color: var(--ua-amber-warm);
    margin-bottom: var(--ua-space-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .source-list,
  .protocol-list,
  .ethics-list {
    list-style: none;
  }

  .source-list li,
  .protocol-list li,
  .ethics-list li {
    padding: var(--ua-space-xs) 0;
    color: var(--ua-grey-concrete);
    position: relative;
    padding-left: 1.5rem;
  }

  .source-list li::before,
  .protocol-list li::before,
  .ethics-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--ua-amber-warm);
    font-weight: bold;
  }

  /* MANIFESTO FOOTER */
  .manifesto-footer {
    padding: var(--ua-space-xl);
    background: var(--ua-black-ink);
    border-top: 4px solid var(--ua-amber-warm);
    text-align: center;
  }

  .manifesto-text {
    max-width: 800px;
    margin: 0 auto var(--ua-space-lg);
  }

  .manifesto-statement {
    font-size: var(--ua-text-xl);
    color: var(--ua-white-paper);
    font-style: italic;
    line-height: 1.6;
    margin-bottom: var(--ua-space-md);
  }

  .signature {
    font-family: 'Staatliches', sans-serif;
    color: var(--ua-amber-warm);
    font-size: var(--ua-text-lg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .institutional-codes {
    display: flex;
    justify-content: center;
    gap: var(--ua-space-md);
    flex-wrap: wrap;
