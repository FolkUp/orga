---
export interface Props {
  currentSection: string;
  investigationTitle: string;
  sections: {
    id: string;
    title: string;
    status: 'completed' | 'current' | 'locked' | 'available';
    progress?: number; // 0-100 percentage
    subsections?: {
      id: string;
      title: string;
      status: 'completed' | 'current' | 'locked' | 'available';
      href: string;
    }[];
    href: string;
    description?: string;
  }[];
  showProgress?: boolean;
  compact?: boolean;
  className?: string;
}

const {
  currentSection,
  investigationTitle,
  sections,
  showProgress = true,
  compact = false,
  className = ''
} = Astro.props;

const navClasses = `investigation-nav ${compact ? 'investigation-nav--compact' : ''} ${className}`.trim();

// Calculate overall progress
const totalSections = sections.length;
const completedSections = sections.filter(section => section.status === 'completed').length;
const currentSectionIndex = sections.findIndex(section => section.id === currentSection);
const overallProgress = totalSections > 0 ? Math.round((completedSections / totalSections) * 100) : 0;

// Status configuration
const statusConfig = {
  completed: {
    label: 'Completed',
    class: 'section-status--completed',
    icon: '✓'
  },
  current: {
    label: 'Current',
    class: 'section-status--current',
    icon: '▶'
  },
  available: {
    label: 'Available',
    class: 'section-status--available',
    icon: '○'
  },
  locked: {
    label: 'Locked',
    class: 'section-status--locked',
    icon: '🔒'
  }
};
---

<nav class={navClasses} role="navigation" aria-label="Investigation sections">
  {!compact && (
    <header class="investigation-nav__header">
      <h2 class="investigation-nav__title">{investigationTitle}</h2>

      {showProgress && (
        <div class="investigation-nav__progress">
          <div class="progress-bar" role="progressbar" aria-valuenow={overallProgress} aria-valuemin="0" aria-valuemax="100" aria-label={`Investigation progress: ${overallProgress}%`}>
            <div class="progress-bar__fill" style={`width: ${overallProgress}%`}></div>
          </div>
          <span class="progress-text" aria-hidden="true">
            {completedSections} of {totalSections} sections completed ({overallProgress}%)
          </span>
        </div>
      )}
    </header>
  )}

  <ol class="investigation-nav__sections">
    {sections.map((section, index) => {
      const statusInfo = statusConfig[section.status];
      const isActive = section.id === currentSection;
      const sectionClasses = `nav-section ${statusInfo.class} ${isActive ? 'nav-section--active' : ''}`;

      return (
        <li class={sectionClasses}>
          <div class="nav-section__main">
            <a
              href={section.status !== 'locked' ? section.href : undefined}
              class={`nav-section__link ${section.status === 'locked' ? 'nav-section__link--disabled' : ''}`}
              aria-current={isActive ? 'page' : undefined}
              aria-disabled={section.status === 'locked' ? 'true' : undefined}
              tabindex={section.status === 'locked' ? -1 : 0}
            >
              <div class="nav-section__header">
                <span class="nav-section__number" aria-hidden="true">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
                <span class={`nav-section__status ${statusInfo.class}`} aria-label={statusInfo.label}>
                  {statusInfo.icon}
                </span>
                <h3 class="nav-section__title">{section.title}</h3>
              </div>

              {section.description && !compact && (
                <p class="nav-section__description">{section.description}</p>
              )}

              {section.progress !== undefined && showProgress && section.status !== 'completed' && (
                <div class="nav-section__progress">
                  <div class="section-progress-bar" role="progressbar" aria-valuenow={section.progress} aria-valuemin="0" aria-valuemax="100">
                    <div class="section-progress-bar__fill" style={`width: ${section.progress}%`}></div>
                  </div>
                  <span class="section-progress-text">{section.progress}%</span>
                </div>
              )}
            </a>

            {section.subsections && section.subsections.length > 0 && !compact && (
              <details class="nav-subsections" open={isActive}>
                <summary class="nav-subsections__toggle">
                  Subsections ({section.subsections.length})
                </summary>
                <ol class="nav-subsections__list">
                  {section.subsections.map((subsection) => {
                    const subStatusInfo = statusConfig[subsection.status];
                    const subIsActive = subsection.id === currentSection;

                    return (
                      <li class={`nav-subsection ${subStatusInfo.class} ${subIsActive ? 'nav-subsection--active' : ''}`}>
                        <a
                          href={subsection.status !== 'locked' ? subsection.href : undefined}
                          class={`nav-subsection__link ${subsection.status === 'locked' ? 'nav-subsection__link--disabled' : ''}`}
                          aria-current={subIsActive ? 'page' : undefined}
                          aria-disabled={subsection.status === 'locked' ? 'true' : undefined}
                          tabindex={subsection.status === 'locked' ? -1 : 0}
                        >
                          <span class={`nav-subsection__status ${subStatusInfo.class}`} aria-label={subStatusInfo.label}>
                            {subStatusInfo.icon}
                          </span>
                          <span class="nav-subsection__title">{subsection.title}</span>
                        </a>
                      </li>
                    );
                  })}
                </ol>
              </details>
            )}
          </div>
        </li>
      );
    })}
  </ol>

  {!compact && (
    <footer class="investigation-nav__footer">
      <div class="nav-legend">
        <h4 class="nav-legend__title">Legend</h4>
        <ul class="nav-legend__items">
          {Object.entries(statusConfig).map(([status, config]) => (
            <li class="nav-legend__item">
              <span class={`nav-legend__icon ${config.class}`} aria-hidden="true">
                {config.icon}
              </span>
              <span class="nav-legend__label">{config.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </footer>
  )}
</nav>

<style>
  .investigation-nav {
    background-color: var(--color-ivory);
    border: 1px solid rgba(26, 54, 93, 0.2);
    border-radius: var(--space-sm);
    padding: var(--space-lg);
    font-family: var(--font-body);
    max-width: 100%;
  }

  .investigation-nav--compact {
    padding: var(--space-md);
    border-radius: var(--space-xs);
  }

  .investigation-nav__header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid rgba(26, 54, 93, 0.1);
  }

  .investigation-nav__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: var(--line-height-heading);
    color: var(--color-bordeaux);
    margin: 0 0 var(--space-md) 0;
  }

  .investigation-nav__progress {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .progress-bar {
    width: 100%;
    height: 8px;
    background-color: rgba(26, 54, 93, 0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-sage) 0%, var(--color-amber) 100%);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .progress-text {
    font-size: 0.875rem;
    color: rgba(45, 55, 72, 0.8);
    font-weight: 600;
  }

  .investigation-nav__sections {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .nav-section {
    border: 1px solid rgba(26, 54, 93, 0.1);
    border-radius: var(--space-sm);
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .nav-section:hover {
    border-color: rgba(26, 54, 93, 0.3);
    box-shadow: 0 2px 8px rgba(26, 54, 93, 0.1);
  }

  .nav-section--active {
    border-color: var(--color-amber);
    background-color: rgba(214, 158, 46, 0.05);
  }

  .nav-section__main {
    position: relative;
  }

  .nav-section__link {
    display: block;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s ease;
  }

  .nav-section__link:hover:not(.nav-section__link--disabled) {
    background-color: rgba(26, 54, 93, 0.05);
  }

  .nav-section__link:focus {
    outline: 2px solid var(--color-amber);
    outline-offset: -2px;
  }

  .nav-section__link--disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .nav-section__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .nav-section__number {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-bordeaux);
    min-width: 2em;
    text-align: center;
  }

  .nav-section__status {
    font-size: 1.25rem;
    min-width: 1.5em;
    text-align: center;
  }

  .section-status--completed .nav-section__status {
    color: var(--color-sage);
  }

  .section-status--current .nav-section__status {
    color: var(--color-amber);
  }

  .section-status--available .nav-section__status {
    color: var(--color-bordeaux);
  }

  .section-status--locked .nav-section__status {
    color: rgba(45, 55, 72, 0.5);
  }

  .nav-section__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: var(--line-height-heading);
    color: var(--color-bordeaux);
    margin: 0;
    flex: 1;
  }

  .section-status--locked .nav-section__title {
    color: rgba(45, 55, 72, 0.6);
  }

  .nav-section__description {
    margin: 0;
    font-size: 0.875rem;
    line-height: var(--line-height-body);
    color: rgba(45, 55, 72, 0.8);
    padding-left: calc(2em + var(--space-md) + 1.5em + var(--space-md));
  }

  .nav-section__progress {
    margin-top: var(--space-sm);
    padding-left: calc(2em + var(--space-md) + 1.5em + var(--space-md));
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .section-progress-bar {
    flex: 1;
    height: 6px;
    background-color: rgba(26, 54, 93, 0.1);
    border-radius: 3px;
    overflow: hidden;
  }

  .section-progress-bar__fill {
    height: 100%;
    background-color: var(--color-amber);
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  .section-progress-text {
    font-size: 0.75rem;
    color: rgba(45, 55, 72, 0.8);
    font-weight: 600;
    min-width: 3em;
    text-align: right;
  }

  .nav-subsections {
    border-top: 1px solid rgba(26, 54, 93, 0.1);
    background-color: rgba(26, 54, 93, 0.02);
  }

  .nav-subsections__toggle {
    padding: var(--space-sm) var(--space-md);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-bordeaux);
    cursor: pointer;
    list-style: none;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .nav-subsections__toggle::-webkit-details-marker {
    display: none;
  }

  .nav-subsections__toggle::before {
    content: "▶";
    margin-right: var(--space-xs);
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .nav-subsections[open] .nav-subsections__toggle::before {
    transform: rotate(90deg);
  }

  .nav-subsections__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-subsection {
    border-top: 1px solid rgba(26, 54, 93, 0.05);
  }

  .nav-subsection:first-child {
    border-top: none;
  }

  .nav-subsection--active {
    background-color: rgba(214, 158, 46, 0.1);
  }

  .nav-subsection__link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    text-decoration: none;
    color: inherit;
    font-size: 0.875rem;
    transition: background-color 0.2s ease;
  }

  .nav-subsection__link:hover:not(.nav-subsection__link--disabled) {
    background-color: rgba(26, 54, 93, 0.05);
  }

  .nav-subsection__link:focus {
    outline: 2px solid var(--color-amber);
    outline-offset: -2px;
  }

  .nav-subsection__link--disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .nav-subsection__status {
    font-size: 1rem;
    min-width: 1.2em;
    text-align: center;
  }

  .nav-subsection__title {
    color: var(--color-bordeaux);
    font-weight: 500;
  }

  .investigation-nav__footer {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(26, 54, 93, 0.1);
  }

  .nav-legend__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-bordeaux);
    margin: 0 0 var(--space-sm) 0;
  }

  .nav-legend__items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-sm);
  }

  .nav-legend__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.75rem;
  }

  .nav-legend__icon {
    font-size: 1rem;
    min-width: 1.2em;
    text-align: center;
  }

  .nav-legend__label {
    color: rgba(45, 55, 72, 0.8);
    font-weight: 500;
  }

  /* Compact mode adjustments */
  .investigation-nav--compact .investigation-nav__sections {
    gap: var(--space-xs);
  }

  .investigation-nav--compact .nav-section {
    border-radius: var(--space-xs);
  }

  .investigation-nav--compact .nav-section__link {
    padding: var(--space-sm);
  }

  .investigation-nav--compact .nav-section__header {
    gap: var(--space-sm);
    margin-bottom: 0;
  }

  .investigation-nav--compact .nav-section__number {
    font-size: 1rem;
    min-width: 1.5em;
  }

  .investigation-nav--compact .nav-section__title {
    font-size: 1rem;
  }

  /* Responsive adjustments */
  @media (max-width: 48rem) {
    .investigation-nav {
      padding: var(--space-md);
    }

    .investigation-nav__header {
      margin-bottom: var(--space-md);
    }

    .investigation-nav__title {
      font-size: 1.25rem;
    }

    .nav-section__header {
      gap: var(--space-sm);
    }

    .nav-section__number {
      font-size: 1rem;
      min-width: 1.5em;
    }

    .nav-section__title {
      font-size: 1rem;
    }

    .nav-section__description,
    .nav-section__progress {
      padding-left: calc(1.5em + var(--space-sm) + 1.2em + var(--space-sm));
    }

    .nav-legend__items {
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
      gap: var(--space-xs);
    }
  }

  /* Focus management */
  .investigation-nav:focus-within {
    outline: 2px solid var(--color-amber);
    outline-offset: 2px;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .nav-section {
      border-width: 2px;
    }

    .progress-bar__fill,
    .section-progress-bar__fill {
      background: var(--color-bordeaux);
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .nav-section,
    .nav-section__link,
    .progress-bar__fill,
    .section-progress-bar__fill,
    .nav-subsections__toggle::before {
      transition: none;
    }
  }
</style>