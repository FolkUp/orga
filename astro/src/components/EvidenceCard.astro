---
import ConfidenceBadge from './ConfidenceBadge.astro';

export interface Props {
  title: string;
  category: 'document' | 'testimony' | 'artifact' | 'media' | 'digital' | 'correspondence';
  status: 'verified' | 'partially_verified' | 'unverified' | 'draft';
  date_collected?: string;
  source?: string;
  significance: 'critical' | 'important' | 'supporting' | 'contextual';
  content: string;
  metadata?: {
    file_type?: string;
    file_size?: string;
    location?: string;
    chain_of_custody?: boolean;
  };
  className?: string;
}

const {
  title,
  category,
  status,
  date_collected,
  source,
  significance,
  content,
  metadata,
  className = ''
} = Astro.props;

const categoryConfig = {
  document: {
    label: 'Document',
    icon: '📄',
    class: 'evidence-card--document'
  },
  testimony: {
    label: 'Testimony',
    icon: '💬',
    class: 'evidence-card--testimony'
  },
  artifact: {
    label: 'Physical Artifact',
    icon: '🔍',
    class: 'evidence-card--artifact'
  },
  media: {
    label: 'Media File',
    icon: '🎵',
    class: 'evidence-card--media'
  },
  digital: {
    label: 'Digital Evidence',
    icon: '💾',
    class: 'evidence-card--digital'
  },
  correspondence: {
    label: 'Correspondence',
    icon: '✉️',
    class: 'evidence-card--correspondence'
  }
};

const significanceConfig = {
  critical: {
    label: 'Critical Evidence',
    class: 'significance--critical'
  },
  important: {
    label: 'Important',
    class: 'significance--important'
  },
  supporting: {
    label: 'Supporting',
    class: 'significance--supporting'
  },
  contextual: {
    label: 'Contextual',
    class: 'significance--contextual'
  }
};

const categoryInfo = categoryConfig[category];
const significanceInfo = significanceConfig[significance];
const cardClasses = `evidence-card ${categoryInfo.class} ${significanceInfo.class} ${className}`.trim();
---

<article class={cardClasses} role="article" aria-labelledby={`evidence-${title.replace(/\s+/g, '-').toLowerCase()}`}>
  <header class="evidence-card__header">
    <div class="evidence-card__title-row">
      <h3 id={`evidence-${title.replace(/\s+/g, '-').toLowerCase()}`} class="evidence-card__title">
        <span class="evidence-card__category-icon" aria-hidden="true">{categoryInfo.icon}</span>
        {title}
      </h3>
      <ConfidenceBadge status={status} />
    </div>

    <div class="evidence-card__meta">
      <span class={`evidence-category ${categoryInfo.class}`} aria-label={`Category: ${categoryInfo.label}`}>
        {categoryInfo.label}
      </span>
      <span class={`significance-indicator ${significanceInfo.class}`} aria-label={`Significance: ${significanceInfo.label}`}>
        {significanceInfo.label}
      </span>
    </div>
  </header>

  <div class="evidence-card__body">
    <div class="evidence-card__content">
      <p>{content}</p>
    </div>

    {(date_collected || source) && (
      <div class="evidence-card__attribution">
        {date_collected && (
          <div class="attribution-item">
            <strong>Collected:</strong>
            <time datetime={date_collected}>{date_collected}</time>
          </div>
        )}
        {source && (
          <div class="attribution-item">
            <strong>Source:</strong>
            <span>{source}</span>
          </div>
        )}
      </div>
    )}

    {metadata && Object.keys(metadata).length > 0 && (
      <details class="evidence-card__metadata">
        <summary class="metadata-toggle">Technical Metadata</summary>
        <dl class="metadata-list">
          {metadata.file_type && (
            <div class="metadata-item">
              <dt>File Type:</dt>
              <dd>{metadata.file_type}</dd>
            </div>
          )}
          {metadata.file_size && (
            <div class="metadata-item">
              <dt>File Size:</dt>
              <dd>{metadata.file_size}</dd>
            </div>
          )}
          {metadata.location && (
            <div class="metadata-item">
              <dt>Location:</dt>
              <dd>{metadata.location}</dd>
            </div>
          )}
          {metadata.chain_of_custody !== undefined && (
            <div class="metadata-item">
              <dt>Chain of Custody:</dt>
              <dd class={metadata.chain_of_custody ? 'custody--verified' : 'custody--unverified'}>
                {metadata.chain_of_custody ? 'Verified' : 'Not Verified'}
              </dd>
            </div>
          )}
        </dl>
      </details>
    )}
  </div>
</article>

<style>
  .evidence-card {
    background-color: var(--color-concrete-light);
    border: 1px solid rgba(26, 54, 93, 0.2);
    border-radius: var(--space-sm);
    padding: var(--space-md);
    margin-bottom: var(--space-md);
    font-family: var(--font-body);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .evidence-card:hover {
    box-shadow: 0 4px 12px rgba(26, 54, 93, 0.15);
  }

  /* Significance-based border styling */
  .significance--critical {
    border-left: 4px solid var(--color-sage-muted);
  }

  .significance--important {
    border-left: 4px solid var(--color-amber-warm);
  }

  .significance--supporting {
    border-left: 4px solid rgba(214, 158, 46, 0.5);
  }

  .significance--contextual {
    border-left: 4px solid rgba(26, 54, 93, 0.3);
  }

  .evidence-card__header {
    margin-bottom: var(--space-md);
  }

  .evidence-card__title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .evidence-card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: var(--line-height-heading);
    color: var(--color-maritime-deep);
    margin: 0;
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .evidence-card__category-icon {
    font-size: 1.25rem;
  }

  .evidence-card__meta {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    align-items: center;
  }

  .evidence-category,
  .significance-indicator {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--space-xs);
    border: 1px solid;
  }

  /* Category styles */
  .evidence-card--document .evidence-category {
    background-color: var(--color-maritime-deep);
    border-color: var(--color-maritime-deep);
    color: var(--color-text-inverse);
  }

  .evidence-card--testimony .evidence-category {
    background-color: var(--color-sage-muted);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .evidence-card--artifact .evidence-category {
    background-color: var(--color-amber-warm);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .evidence-card--media .evidence-category,
  .evidence-card--digital .evidence-category,
  .evidence-card--correspondence .evidence-category {
    background-color: rgba(214, 158, 46, 0.3);
    border-color: var(--color-amber-warm);
    color: var(--color-text-primary);
  }

  /* Significance indicator styles */
  .significance--critical .significance-indicator {
    background-color: var(--color-sage-muted);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .significance--important .significance-indicator {
    background-color: var(--color-amber-warm);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .significance--supporting .significance-indicator {
    background-color: rgba(214, 158, 46, 0.3);
    border-color: var(--color-amber-warm);
    color: var(--color-text-primary);
  }

  .significance--contextual .significance-indicator {
    background-color: var(--color-concrete-light);
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }

  .evidence-card__body {
    line-height: var(--line-height-body);
  }

  .evidence-card__content {
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .evidence-card__content p {
    margin: 0;
  }

  .evidence-card__attribution {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
    padding: var(--space-sm);
    background-color: rgba(26, 54, 93, 0.05);
    border-radius: var(--space-xs);
    margin-bottom: var(--space-md);
    font-size: 0.875rem;
  }

  .attribution-item {
    display: flex;
    gap: var(--space-xs);
  }

  .attribution-item strong {
    color: var(--color-maritime-deep);
    font-weight: 600;
  }

  .evidence-card__metadata {
    border-top: 1px solid rgba(26, 54, 93, 0.1);
    padding-top: var(--space-sm);
  }

  .metadata-toggle {
    font-weight: 600;
    color: var(--color-maritime-deep);
    cursor: pointer;
    padding: var(--space-xs) 0;
    list-style: none;
  }

  .metadata-toggle::-webkit-details-marker {
    display: none;
  }

  .metadata-toggle::before {
    content: "▶";
    margin-right: var(--space-xs);
    transition: transform 0.2s ease;
  }

  .evidence-card__metadata[open] .metadata-toggle::before {
    transform: rotate(90deg);
  }

  .metadata-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-sm);
    padding: var(--space-sm) 0;
    font-size: 0.875rem;
  }

  .metadata-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .metadata-item dt {
    font-weight: 600;
    color: var(--color-maritime-deep);
  }

  .metadata-item dd {
    margin: 0;
    color: var(--color-text-primary);
  }

  .custody--verified {
    color: var(--color-sage-muted);
    font-weight: 600;
  }

  .custody--unverified {
    color: var(--color-amber-warm);
    font-weight: 600;
  }

  /* Responsive adjustments */
  @media (max-width: 48rem) {
    .evidence-card__title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .evidence-card__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .evidence-card__attribution {
      grid-template-columns: 1fr;
    }

    .metadata-list {
      grid-template-columns: 1fr;
    }
  }

  /* Focus management */
  .evidence-card:focus-within {
    outline: 2px solid var(--color-amber-warm);
    outline-offset: 2px;
  }
</style>