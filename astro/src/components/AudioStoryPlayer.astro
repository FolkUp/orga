---
/**
 * Underground Academia Audio Investigation Player
 * Soviet Constructivist + Hip-hop + Academic Authority aesthetic
 */

interface Props {
  title: string;
  duration?: string;
  audioSrc: string;
  transcript: Array<{
    start: number;
    end: number;
    speaker?: string;
    text: string;
    chapter?: string;
    evidence?: Array<{
      type: 'document' | 'image' | 'link';
      title: string;
      url: string;
      description?: string;
    }>;
  }>;
  chapters: Array<{
    title: string;
    timestamp: number;
    description?: string;
  }>;
}

const { title, duration = "00:00", audioSrc, transcript, chapters } = Astro.props;
---

<div class="audio-story-player underground-radio-station" data-audio-src={audioSrc}>
  <!-- Underground Radio Header Section -->
  <header class="radio-station-header">
    <!-- Broadcast Identification -->
    <div class="station-identification">
      <div class="frequency-display">
        <span class="frequency-number">108.4</span>
        <span class="frequency-unit">FM</span>
      </div>
      <div class="station-callsign">
        <span class="underground-designation">UNDERGROUND</span>
        <span class="radio-designation">RESEARCH RADIO</span>
      </div>
      <div class="transmission-status">
        <div class="signal-strength-indicator">
          <div class="signal-bar signal-1 active"></div>
          <div class="signal-bar signal-2 active"></div>
          <div class="signal-bar signal-3 active"></div>
          <div class="signal-bar signal-4 active"></div>
          <div class="signal-bar signal-5"></div>
        </div>
        <span class="broadcast-status">ON AIR</span>
      </div>
    </div>

    <!-- Investigation Metadata -->
    <div class="investigation-meta">
      <h2 class="investigation-title">{title}</h2>
      <div class="broadcast-metadata">
        <div class="metadata-item">
          <span class="meta-label">DURATION</span>
          <span class="meta-value duration-display">{duration}</span>
        </div>
        <div class="metadata-item">
          <span class="meta-label">CLASSIFICATION</span>
          <span class="meta-value classification">INVESTIGATIVE AUDIO</span>
        </div>
        <div class="metadata-item">
          <span class="meta-label">VERIFICATION</span>
          <span class="meta-value verification-status">PEER REVIEWED</span>
        </div>
      </div>
    </div>

    <!-- Academic Credentials -->
    <div class="academic-credentials">
      <div class="credential-badge">
        <span class="credential-text">ОРГА RESEARCH INSTITUTE</span>
        <span class="credential-code">REG-2024-UA-001</span>
      </div>
    </div>
  </header>

  <!-- Underground Control Panel -->
  <section class="underground-control-panel">
    <div class="primary-broadcast-controls">
      <button class="power-control-btn play-pause-btn" aria-label="Power On/Off">
        <div class="control-face">
          <svg class="power-on-icon play-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5,3 19,12 5,21 5,3"></polygon>
          </svg>
          <svg class="power-off-icon pause-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="6" y="4" width="4" height="16"></rect>
            <rect x="14" y="4" width="4" height="16"></rect>
          </svg>
        </div>
        <div class="control-label">POWER</div>
      </button>

      <div class="transmission-timer">
        <div class="timer-display">
          <span class="current-time">00:00</span>
          <span class="time-separator">:</span>
          <span class="total-time">{duration}</span>
        </div>
        <div class="timer-labels">
          <span class="label-current">ELAPSED</span>
          <span class="label-total">TOTAL</span>
        </div>
      </div>
    </div>

    <!-- Industrial Progress System -->
    <div class="industrial-progress-system">
      <div class="progress-frame">
        <div class="progress-industrial-track">
          <div class="progress-fill-angular"></div>
          <div class="progress-handle-geometric"></div>

          <!-- Investigation Chapter Markers -->
          <div class="investigation-markers">
            {chapters.map((chapter, index) => (
              <button
                class="chapter-investigation-marker"
                data-timestamp={chapter.timestamp}
                aria-label={`Jump to ${chapter.title}`}
              >
                <div class="marker-geometric-indicator"></div>
                <div class="investigation-chapter-tooltip">
                  <div class="tooltip-header">
                    <strong class="chapter-designation">{chapter.title}</strong>
                  </div>
                  {chapter.description && (
                    <div class="chapter-methodology">
                      <p>{chapter.description}</p>
                    </div>
                  )}
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Progress Grid Overlay -->
      <div class="constructivist-grid-overlay">
        <div class="grid-line vertical"></div>
        <div class="grid-line vertical"></div>
        <div class="grid-line horizontal"></div>
      </div>
    </div>

    <!-- Research Control Panel -->
    <div class="research-control-panel">
      <button class="research-control-btn speed-control" aria-label="Analysis Speed">
        <span class="control-value">1×</span>
        <span class="control-designation">SPEED</span>
      </button>

      <button class="research-control-btn transcript-toggle active" aria-label="Research Transcript">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14,2 14,8 20,8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10,9 9,9 8,9"></polyline>
        </svg>
        <span class="control-designation">TRANSCRIPT</span>
      </button>

      <button class="research-control-btn volume-control" aria-label="Audio Level">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        </svg>
        <span class="control-designation">LEVEL</span>
      </button>
    </div>
  </section>

  <!-- Research Documentation Section -->
  <section class="research-documentation-section">
    <div class="documentation-container">
      <div class="documentation-header">
        <div class="section-designation">
          <h3 class="section-title">INVESTIGATION TRANSCRIPT</h3>
          <span class="section-subtitle">Interactive Research Documentation</span>
        </div>
        <div class="documentation-instructions">
          <p>CLICK ANY SEGMENT TO JUMP TO THAT MOMENT IN THE INVESTIGATION</p>
        </div>
      </div>

      <div class="research-transcript-content">
        {transcript.map((segment, index) => (
          <div
            class="research-segment"
            data-start={segment.start}
            data-end={segment.end}
            data-segment={index}
          >
            {segment.chapter && (
              <div class="chapter-investigation-break">
                <div class="chapter-designation-header">
                  <h4 class="investigation-chapter-title">{segment.chapter}</h4>
                  <div class="chapter-separator-line"></div>
                </div>
              </div>
            )}

            <div class="segment-documentation">
              {segment.speaker && (
                <div class="researcher-identification">
                  <span class="researcher-callsign">{segment.speaker}</span>
                </div>
              )}

              <div class="research-statement">
                <p class="statement-text">{segment.text}</p>
              </div>

              {segment.evidence && segment.evidence.length > 0 && (
                <div class="evidence-documentation">
                  <button class="evidence-access-control" aria-label="Access Evidence Files">
                    <div class="evidence-indicator">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V8a2 2 0 00-2-2h-8l-2-2z"/>
                      </svg>
                      <span class="evidence-count">{segment.evidence.length}</span>
                    </div>
                    <span class="evidence-designation">EVIDENCE FILES</span>
                  </button>

                  <div class="evidence-archive-panel">
                    {segment.evidence.map((evidence, evidenceIndex) => (
                      <div class="evidence-file-entry">
                        <div class="file-classification-label">
                          <span class="classification-badge">{evidence.type.toUpperCase()}</span>
                        </div>
                        <div class="file-access-info">
                          <a href={evidence.url} class="evidence-file-link" target="_blank" rel="noopener noreferrer">
                            <div class="file-designation">
                              <h5 class="file-title">{evidence.title}</h5>
                              {evidence.description && (
                                <p class="file-description">{evidence.description}</p>
                              )}
                            </div>
                          </a>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hidden Audio Element -->
  <audio class="audio-element" preload="metadata">
    <source src={audioSrc} type="audio/mpeg">
    <source src={audioSrc.replace('.mp3', '.ogg')} type="audio/ogg">
    Your browser does not support the audio element.
  </audio>
</div>

<style>
  /* UNDERGROUND ACADEMIA RADIO STATION STYLING */
  .audio-story-player.underground-radio-station {
    /* Underground Academia Color System */
    --ua-maritime-deep: #0a1728;
    --ua-maritime-medium: #1a365d;
    --ua-amber-warm: #d69e2e;
    --ua-amber-bright: #f6e05e;
    --ua-red-signal: #e53e3e;
    --ua-grey-concrete: #718096;
    --ua-white-paper: #f7fafc;
    --ua-black-ink: #1a202c;

    /* Industrial Design System */
    --ua-panel-primary: var(--ua-black-ink);
    --ua-panel-secondary: var(--ua-maritime-deep);
    --ua-panel-elevated: var(--ua-maritime-medium);
    --ua-border-industrial: #4a5568;
    --ua-text-primary: var(--ua-white-paper);
    --ua-text-secondary: var(--ua-grey-concrete);
    --ua-accent-warm: var(--ua-amber-warm);
    --ua-accent-signal: var(--ua-red-signal);

    /* Constructivist Grid System */
    --ua-spacing-xs: 0.5rem;
    --ua-spacing-sm: 1rem;
    --ua-spacing-md: 1.5rem;
    --ua-spacing-lg: 2rem;
    --ua-spacing-xl: 3rem;

    /* Industrial Effects */
    --ua-shadow-industrial:
      0 0 0 1px rgba(113, 128, 150, 0.2),
      0 4px 16px rgba(0, 0, 0, 0.8),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    --ua-shadow-elevated:
      0 0 0 2px var(--ua-amber-warm),
      0 8px 32px rgba(0, 0, 0, 0.9),
      inset 0 2px 0 rgba(255, 255, 255, 0.1);

    background: var(--ua-panel-primary);
    border: 3px solid var(--ua-border-industrial);
    color: var(--ua-text-primary);
    font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    overflow: hidden;
    max-width: 100%;
    margin: var(--ua-spacing-lg) 0;
    box-shadow: var(--ua-shadow-industrial);
    position: relative;

    /* Industrial noise texture */
    background-image:
      radial-gradient(circle at 25% 25%, rgba(215, 158, 46, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 75% 75%, rgba(229, 62, 62, 0.02) 0%, transparent 50%);
  }

  /* RADIO STATION HEADER */
  .radio-station-header {
    background:
      linear-gradient(135deg, var(--ua-panel-secondary) 0%, var(--ua-panel-elevated) 100%),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 10px,
        rgba(215, 158, 46, 0.05) 10px,
        rgba(215, 158, 46, 0.05) 20px
      );
    padding: var(--ua-spacing-lg);
    border-bottom: 2px solid var(--ua-amber-warm);
    position: relative;
    overflow: hidden;
  }

  .radio-station-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg,
      var(--ua-red-signal) 0%,
      var(--ua-amber-warm) 50%,
      var(--ua-red-signal) 100%);
    animation: signal-sweep 3s ease-in-out infinite;
  }

  @keyframes signal-sweep {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(100%); }
  }

  /* BROADCAST IDENTIFICATION */
  .station-identification {
    display: flex;
    align-items: center;
    gap: var(--ua-spacing-lg);
    margin-bottom: var(--ua-spacing-md);
  }

  .frequency-display {
    display: flex;
    align-items: baseline;
    background: var(--ua-black-ink);
    border: 2px solid var(--ua-amber-warm);
    padding: var(--ua-spacing-sm) var(--ua-spacing-md);
    font-family: 'JetBrains Mono', monospace;
  }

  .frequency-number {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ua-amber-warm);
    line-height: 1;
  }

  .frequency-unit {
    font-size: 0.875rem;
    color: var(--ua-text-secondary);
    margin-left: 0.25rem;
  }

  .station-callsign {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .underground-designation {
    font-family: 'Staatliches', 'Arial Black', sans-serif;
    font-size: 1.25rem;
    color: var(--ua-red-signal);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .radio-designation {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--ua-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
  }

  .transmission-status {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ua-spacing-xs);
  }

  .signal-strength-indicator {
    display: flex;
    gap: 2px;
    align-items: end;
    height: 24px;
  }

  .signal-bar {
    width: 4px;
    background: rgba(113, 128, 150, 0.3);
    transition: background-color 0.3s ease;
  }

  .signal-1 { height: 6px; }
  .signal-2 { height: 10px; }
  .signal-3 { height: 14px; }
  .signal-4 { height: 18px; }
  .signal-5 { height: 24px; }

  .signal-bar.active {
    background: var(--ua-amber-warm);
    box-shadow: 0 0 4px var(--ua-amber-warm);
  }

  .broadcast-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--ua-red-signal);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* INVESTIGATION METADATA */
  .investigation-meta {
    margin-bottom: var(--ua-spacing-lg);
  }

  .investigation-title {
    font-family: 'Staatliches', 'Arial Black', sans-serif;
    font-size: 1.5rem;
    color: var(--ua-text-primary);
    margin: 0 0 var(--ua-spacing-sm) 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .broadcast-metadata {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--ua-spacing-sm);
  }

  .metadata-item {
    background: var(--ua-black-ink);
    border: 1px solid var(--ua-border-industrial);
    padding: var(--ua-spacing-xs) var(--ua-spacing-sm);
    display: flex;
    flex-direction: column;
  }

  .meta-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--ua-amber-warm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }

  .meta-value {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--ua-text-primary);
    font-weight: 500;
  }

  .duration-display {
    font-family: 'JetBrains Mono', monospace;
    color: var(--ua-amber-warm);
    font-weight: 700;
  }

  .verification-status {
    color: var(--ua-red-signal);
    font-weight: 600;
  }

  /* ACADEMIC CREDENTIALS */
  .academic-credentials {
    display: flex;
    justify-content: flex-end;
  }

  .credential-badge {
    background: var(--ua-amber-warm);
    color: var(--ua-black-ink);
    padding: var(--ua-spacing-xs) var(--ua-spacing-sm);
    border: 2px solid var(--ua-black-ink);
    transform: rotate(-2deg);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .credential-text {
    font-family: 'Staatliches', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .credential-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    opacity: 0.8;
    margin-top: 0.125rem;
  }

  /* UNDERGROUND CONTROL PANEL */
  .underground-control-panel {
    background: var(--ua-panel-secondary);
    padding: var(--ua-spacing-lg);
    border-bottom: 1px solid var(--ua-border-industrial);
    position: relative;
  }

  .underground-control-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: var(--ua-spacing-lg);
    right: var(--ua-spacing-lg);
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--ua-amber-warm) 20%,
      var(--ua-amber-warm) 80%,
      transparent 100%);
  }

  /* PRIMARY BROADCAST CONTROLS */
  .primary-broadcast-controls {
    display: flex;
    align-items: center;
    gap: var(--ua-spacing-xl);
    margin-bottom: var(--ua-spacing-lg);
  }

  .power-control-btn {
    width: 80px;
    height: 80px;
    background: var(--ua-black-ink);
    border: 3px solid var(--ua-border-industrial);
    color: var(--ua-text-secondary);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .power-control-btn::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, var(--ua-amber-warm), var(--ua-red-signal), var(--ua-amber-warm));
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .power-control-btn:hover,
  .power-control-btn.playing {
    border-color: var(--ua-amber-warm);
    color: var(--ua-amber-warm);
    transform: scale(1.02);
    box-shadow:
      0 0 20px rgba(215, 158, 46, 0.3),
      inset 0 2px 0 rgba(255, 255, 255, 0.1);
  }

  .power-control-btn.playing::before {
    opacity: 1;
  }

  .control-face {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .control-face svg {
    width: 20px;
    height: 20px;
  }

  .control-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .transmission-timer {
    display: flex;
    flex-direction: column;
    gap: var(--ua-spacing-xs);
  }

  .timer-display {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ua-black-ink);
    border: 2px solid var(--ua-border-industrial);
    padding: var(--ua-spacing-sm) var(--ua-spacing-md);
  }

  .current-time {
    color: var(--ua-amber-warm);
  }

  .time-separator {
    color: var(--ua-text-secondary);
  }

  .total-time {
    color: var(--ua-text-primary);
  }

  .timer-labels {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .label-current,
  .label-total {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    color: var(--ua-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* INDUSTRIAL PROGRESS SYSTEM */
  .industrial-progress-system {
    margin-bottom: var(--ua-spacing-lg);
    position: relative;
  }

  .progress-frame {
    background: var(--ua-black-ink);
    border: 2px solid var(--ua-border-industrial);
    padding: var(--ua-spacing-sm);
    position: relative;
  }

  .progress-industrial-track {
    height: 16px;
    background: var(--ua-panel-primary);
    border: 1px solid var(--ua-border-industrial);
    position: relative;
    cursor: pointer;
  }

  .progress-fill-angular {
    height: 100%;
    background: linear-gradient(90deg,
      var(--ua-red-signal) 0%,
      var(--ua-amber-warm) 50%,
      var(--ua-amber-warm) 100%);
    width: 0%;
    transition: width 0.1s ease-out;
    position: relative;
    overflow: hidden;
  }

  .progress-fill-angular::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent 0px,
      rgba(255,255,255,0.1) 2px,
      transparent 4px
    );
    animation: industrial-scan 2s linear infinite;
  }

  @keyframes industrial-scan {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .progress-handle-geometric {
    width: 24px;
    height: 24px;
    background: var(--ua-amber-warm);
    border: 2px solid var(--ua-black-ink);
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%) rotate(45deg);
    cursor: grab;
    transition: all 0.2s ease;
    box-shadow: 0 0 8px rgba(215, 158, 46, 0.4);
  }

  .progress-handle-geometric:hover,
  .progress-handle-geometric:active {
    transform: translate(-50%, -50%) rotate(45deg) scale(1.2);
    box-shadow: 0 0 16px var(--ua-amber-warm);
  }

  /* INVESTIGATION MARKERS */
  .investigation-markers {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .chapter-investigation-marker {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    pointer-events: all;
    z-index: 10;
    display: none; /* Hidden until positioned by JavaScript */
  }

  .marker-geometric-indicator {
    width: 12px;
    height: 12px;
    background: var(--ua-text-primary);
    border: 2px solid var(--ua-black-ink);
    transform: rotate(45deg);
    transition: all 0.2s ease;
  }

  .chapter-investigation-marker:hover .marker-geometric-indicator {
    background: var(--ua-amber-warm);
    transform: rotate(45deg) scale(1.3);
