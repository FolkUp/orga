</style>

<script>
class UndergroundAudioPlayer {
  constructor(container) {
    this.container = container;
    this.audio = container.querySelector('.audio-element');
    this.playPauseBtn = container.querySelector('.play-pause-btn');
    this.playIcon = container.querySelector('.play-icon');
    this.pauseIcon = container.querySelector('.pause-icon');
    this.currentTimeSpan = container.querySelector('.current-time');
    this.progressFill = container.querySelector('.progress-fill-angular');
    this.progressHandle = container.querySelector('.progress-handle-geometric');
    this.progressTrack = container.querySelector('.progress-industrial-track');
    this.chapterMarkers = container.querySelectorAll('.chapter-investigation-marker');
    this.transcriptSegments = container.querySelectorAll('.research-segment');
    this.evidenceToggles = container.querySelectorAll('.evidence-access-control');
    this.speedControl = container.querySelector('.speed-control');
    this.transcriptToggle = container.querySelector('.transcript-toggle');
    this.transcriptSection = container.querySelector('.research-documentation-section');

    this.isPlaying = false;
    this.currentSegment = null;
    this.playbackSpeeds = [0.75, 1, 1.25, 1.5, 2];
    this.currentSpeedIndex = 1;

    this.init();
  }

  init() {
    this.bindEvents();
    this.initializeChapterMarkers();
    this.initializeTranscriptSegments();
    this.initializeEvidenceToggles();
    this.updateProgress();
  }

  bindEvents() {
    // Play/Pause control
    this.playPauseBtn.addEventListener('click', () => this.togglePlayPause());

    // Progress tracking
    this.audio.addEventListener('timeupdate', () => this.updateProgress());
    this.audio.addEventListener('loadedmetadata', () => this.positionChapterMarkers());
    this.progressTrack.addEventListener('click', (e) => this.seekToPosition(e));

    // Speed control
    this.speedControl.addEventListener('click', () => this.cyclePlaybackSpeed());

    // Transcript toggle
    this.transcriptToggle.addEventListener('click', () => this.toggleTranscript());

    // Handle drag
    this.progressHandle.addEventListener('mousedown', (e) => this.startDragging(e));
    document.addEventListener('mousemove', (e) => this.handleDragging(e));
    document.addEventListener('mouseup', () => this.stopDragging());

    this.isDragging = false;
  }

  togglePlayPause() {
    if (this.isPlaying) {
      this.audio.pause();
      this.playIcon.classList.remove('hidden');
      this.pauseIcon.classList.add('hidden');
      this.playPauseBtn.classList.remove('playing');
    } else {
      this.audio.play();
      this.playIcon.classList.add('hidden');
      this.pauseIcon.classList.remove('hidden');
      this.playPauseBtn.classList.add('playing');
    }
    this.isPlaying = !this.isPlaying;
  }

  updateProgress() {
    if (this.audio.duration && !this.isDragging) {
      const progress = (this.audio.currentTime / this.audio.duration) * 100;
      this.progressFill.style.width = `${progress}%`;
      this.progressHandle.style.left = `${progress}%`;

      // Update current time
      const minutes = Math.floor(this.audio.currentTime / 60);
      const seconds = Math.floor(this.audio.currentTime % 60);
      this.currentTimeSpan.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;

      // Update current transcript segment
      this.updateCurrentTranscriptSegment();
    }
  }

  seekToPosition(e) {
    const rect = this.progressTrack.getBoundingClientRect();
    const position = (e.clientX - rect.left) / rect.width;
    const time = position * this.audio.duration;
    this.audio.currentTime = time;
  }

  startDragging(e) {
    this.isDragging = true;
    this.progressHandle.style.cursor = 'grabbing';
  }

  handleDragging(e) {
    if (this.isDragging) {
      const rect = this.progressTrack.getBoundingClientRect();
      let position = (e.clientX - rect.left) / rect.width;
      position = Math.max(0, Math.min(1, position));

      this.progressFill.style.width = `${position * 100}%`;
      this.progressHandle.style.left = `${position * 100}%`;

      if (this.audio.duration) {
        this.audio.currentTime = position * this.audio.duration;
      }
    }
  }

  stopDragging() {
    this.isDragging = false;
    this.progressHandle.style.cursor = 'grab';
  }

  initializeChapterMarkers() {
    this.chapterMarkers.forEach((marker) => {
      marker.addEventListener('click', () => {
        const timestamp = parseFloat(marker.dataset.timestamp);
        this.audio.currentTime = timestamp;
      });
    });
  }

  positionChapterMarkers() {
    this.chapterMarkers.forEach((marker) => {
      const timestamp = parseFloat(marker.dataset.timestamp);
      const position = (timestamp / this.audio.duration) * 100;
      marker.style.left = `${position}%`;
      marker.style.display = 'block';
    });
  }

  initializeTranscriptSegments() {
    this.transcriptSegments.forEach((segment) => {
      segment.addEventListener('click', () => {
        const start = parseFloat(segment.dataset.start);
        this.audio.currentTime = start;
      });
    });
  }

  updateCurrentTranscriptSegment() {
    const currentTime = this.audio.currentTime;
    let currentSegment = null;

    this.transcriptSegments.forEach((segment) => {
      const start = parseFloat(segment.dataset.start);
      const end = parseFloat(segment.dataset.end);

      segment.classList.remove('current', 'active');

      if (currentTime >= start && currentTime <= end) {
        segment.classList.add('current');
        currentSegment = segment;
      }
    });

    this.currentSegment = currentSegment;
  }

  initializeEvidenceToggles() {
    this.evidenceToggles.forEach((toggle) => {
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const panel = toggle.nextElementSibling;
        panel.classList.toggle('show');
      });
    });
  }

  cyclePlaybackSpeed() {
    this.currentSpeedIndex = (this.currentSpeedIndex + 1) % this.playbackSpeeds.length;
    const speed = this.playbackSpeeds[this.currentSpeedIndex];
    this.audio.playbackRate = speed;
    this.speedControl.querySelector('.control-value').textContent = `${speed}×`;
  }

  toggleTranscript() {
    this.transcriptSection.style.display =
      this.transcriptSection.style.display === 'none' ? 'block' : 'none';
    this.transcriptToggle.classList.toggle('active');
  }
}

// Initialize player when DOM loads
document.addEventListener('DOMContentLoaded', () => {
  const players = document.querySelectorAll('.underground-radio-station');
  players.forEach(player => new UndergroundAudioPlayer(player));
});
</script>