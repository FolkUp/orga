---
// ReadingModeToggle.astro — JavaScript-based toggle с localStorage persistence
// Accessibility: ARIA states, keyboard shortcut Alt+R, focus management
interface Props {
  position?: 'top' | 'sidebar';
}

const { position = 'top' } = Astro.props;
---

<div
  class={`reading-mode-toggle reading-mode-toggle--${position}`}
  data-reading-mode-toggle
  role="region"
  aria-label="Reading mode controls"
>
  <button
    id="reading-mode-toggle-button"
    class="reading-mode-button"
    aria-pressed="false"
    aria-describedby="reading-mode-help"
    title="Toggle reading mode (Alt+R)"
    data-reading-mode-button
  >
    <span class="reading-mode-icon" aria-hidden="true">📖</span>
    <span class="reading-mode-label">Reading Mode</span>
  </button>

  <div id="reading-mode-help" class="reading-mode-help" aria-live="polite">
    <span class="sr-only">Press Alt+R or click to toggle between full multimedia and text-only reading experience</span>
  </div>
</div>

<!-- Announcement region for screen readers -->
<div
  id="reading-mode-announcements"
  class="sr-only"
  aria-live="polite"
  aria-atomic="true"
></div>

<style>
/* Underground Academia Reading Mode Toggle */
.reading-mode-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 1rem 0;
}

.reading-mode-toggle--top {
  justify-content: flex-start;
  border-bottom: 1px solid var(--color-sage-light, #a8b499);
  padding-bottom: 0.75rem;
  margin-bottom: 1.5rem;
}

.reading-mode-button {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;

  /* Typography - Underground Academia */
  font-family: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1.5;

  /* Layout */
  padding: 0.5rem 0.75rem;
  border: 1.5px solid var(--color-bordeaux, #7D4450);
  border-radius: 0.375rem;

  /* Colors - Underground Academia palette */
  background: var(--color-ivory, #FEFCF6);
  color: var(--color-bordeaux, #7D4450);

  /* Interaction */
  cursor: pointer;
  transition: all 0.2s ease-out;

  /* Touch targets - minimum 44×44px */
  min-width: 44px;
  min-height: 44px;
}

.reading-mode-button:hover {
  background: var(--color-bordeaux, #7D4450);
  color: var(--color-ivory, #FEFCF6);
  transform: translateY(-1px);
  box-shadow: 0 2px 4px rgba(125, 68, 80, 0.2);
}

.reading-mode-button:focus {
  outline: 3px solid var(--color-amber, #E8AD4A);
  outline-offset: 2px;
}

.reading-mode-button[aria-pressed="true"] {
  background: var(--color-sage, #839E75);
  border-color: var(--color-sage, #839E75);
  color: var(--color-ivory, #FEFCF6);
}

.reading-mode-button[aria-pressed="true"]:hover {
  background: var(--color-sage-dark, #6b8160);
  border-color: var(--color-sage-dark, #6b8160);
}

.reading-mode-icon {
  font-size: 1rem;
  line-height: 1;
}

.reading-mode-label {
  white-space: nowrap;
}

.reading-mode-help {
  font-size: 0.75rem;
  color: var(--color-sage, #839E75);
}

/* Screen reader only content */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Hero visualization delay — progressive enhancement */
.reading-mode-multimedia {
  opacity: 0;
  animation: hero-fade-in 0.8s ease-out 1.5s forwards;
}

@keyframes hero-fade-in {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Reading mode active state modifications */
:global(.reading-mode) .reading-mode-multimedia {
  display: none !important;
}

/* Text alternatives show in reading mode */
:global(.reading-mode) .reading-mode-text-alternative {
  display: block !important;
}

/* Typography optimizations for reading mode */
:global(.reading-mode) .longform-content {
  line-height: 1.6;
  font-size: 1.125rem;
  max-width: 65ch;
  margin-left: auto;
  margin-right: auto;
}

/* Enhanced reading mode typography */
:global(.reading-mode) .longform-content h2 {
  margin-top: 2rem;
  margin-bottom: 1rem;
  font-size: 1.5rem;
  line-height: 1.4;
}

:global(.reading-mode) .longform-content h3 {
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
  font-size: 1.25rem;
  line-height: 1.4;
}

:global(.reading-mode) .longform-content p {
  margin-bottom: 1.125rem;
  text-align: justify;
  word-spacing: 0.1em;
}

:global(.reading-mode) .longform-content blockquote {
  margin: 1.5rem 0;
  padding-left: 1.5rem;
  border-left: 3px solid var(--color-sage, #839E75);
  font-style: italic;
  color: var(--color-bordeaux, #7D4450);
}

/* Underground Academia focus rings */
:global(button:focus),
:global(a:focus),
:global(input:focus),
:global(select:focus),
:global(textarea:focus),
:global([tabindex]:focus) {
  outline: 3px solid var(--color-amber, #E8AD4A);
  outline-offset: 2px;
  border-radius: 0.25rem;
}

/* Focus-visible for modern browsers */
:global(button:focus-visible),
:global(a:focus-visible),
:global(input:focus-visible),
:global(select:focus-visible),
:global(textarea:focus-visible),
:global([tabindex]:focus-visible) {
  outline: 3px solid var(--color-amber, #E8AD4A);
  outline-offset: 2px;
}

/* Remove focus outline for mouse users */
:global(button:focus:not(:focus-visible)),
:global(a:focus:not(:focus-visible)),
:global(input:focus:not(:focus-visible)),
:global(select:focus:not(:focus-visible)),
:global(textarea:focus:not(:focus-visible)),
:global([tabindex]:focus:not(:focus-visible)) {
  outline: none;
}

/* Loading states — skeleton screens with Underground Academia styling */
.reading-mode-multimedia:not([data-hydrated]) {
  background: linear-gradient(
    90deg,
    var(--color-ivory, #FEFCF6) 0%,
    rgba(131, 158, 117, 0.1) 50%,
    var(--color-ivory, #FEFCF6) 100%
  );
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
  border: 1px solid var(--color-sage-light, #a8b499);
  border-radius: 0.5rem;
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.reading-mode-multimedia:not([data-hydrated])::before {
  content: "Loading multimedia content...";
  color: var(--color-sage, #839E75);
  font-size: 0.875rem;
  font-weight: 500;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* Hide skeleton once hydrated */
.reading-mode-multimedia[data-hydrated] {
  background: none;
  animation: none;
  border: none;
}

.reading-mode-multimedia[data-hydrated]::before {
  display: none;
}

/* Print stylesheet integration */
@media print {
  .reading-mode-toggle {
    display: none;
  }

  /* Apply reading mode styles to print */
  .reading-mode-multimedia {
    display: none !important;
  }

  .reading-mode-text-alternative {
    display: block !important;
  }

  .longform-content {
    line-height: 1.6;
    font-size: 12pt;
    max-width: none;
  }
}

/* Respect prefers-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .reading-mode-button {
    transition: none;
  }

  .reading-mode-button:hover {
    transform: none;
  }

  /* Disable hero animation for reduced motion preference */
  .reading-mode-multimedia {
    animation: none;
    opacity: 1;
    transform: none;
  }
}

/* Mobile optimizations */
@media (max-width: 768px) {
  .reading-mode-toggle--top {
    position: sticky;
    top: 0;
    background: var(--color-ivory, #FEFCF6);
    z-index: 10;
    padding: 0.75rem 0;
    margin: 0 0 1rem 0;
    border-bottom: 2px solid var(--color-sage-light, #a8b499);
  }

  .reading-mode-button {
    font-size: 0.8125rem;
    padding: 0.625rem 1rem;
    /* Ensure adequate touch target on mobile */
    min-width: 48px;
    min-height: 48px;
  }
}
</style>

<script>
/**
 * ReadingModeManager - JavaScript state management with localStorage persistence
 * Accessibility: ARIA updates, keyboard shortcut, screen reader announcements
 * Performance: debounced localStorage writes, minimal DOM queries
 */
class ReadingModeManager {
  constructor() {
    this.isReadingMode = false;
    this.button = null;
    this.announcements = null;
    this.init();
  }

  init() {
    // Wait for DOM to be ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => this.setup());
    } else {
      this.setup();
    }
  }

  setup() {
    this.button = document.querySelector('[data-reading-mode-button]');
    this.announcements = document.getElementById('reading-mode-announcements');

    if (!this.button) {
      console.warn('ReadingModeToggle: button not found');
      return;
    }

    // Load saved state
    this.loadState();

    // Event listeners
    this.button.addEventListener('click', (e) => {
      e.preventDefault();
      this.toggle();
    });

    // Keyboard shortcut: Alt+R
    document.addEventListener('keydown', (e) => {
      if (e.altKey && e.key === 'r') {
        e.preventDefault();
        this.toggle();
        // Focus the button for keyboard users
        this.button.focus();
      }
    });

    // Mark multimedia components as hydrated after initial load
    this.markComponentsHydrated();

    // Apply initial state
    this.updateDOM();
  }

  markComponentsHydrated() {
    // Wait for initial DOM settle, then mark multimedia components as loaded
    setTimeout(() => {
      const multimediaElements = document.querySelectorAll('.reading-mode-multimedia');
      multimediaElements.forEach(element => {
        element.setAttribute('data-hydrated', 'true');
      });
    }, 100);
  }

  loadState() {
    try {
      const saved = localStorage.getItem('orga-reading-mode');
      this.isReadingMode = saved === 'true';
    } catch (e) {
      console.warn('ReadingModeToggle: localStorage unavailable, defaulting to false');
      this.isReadingMode = false;
    }
  }

  saveState() {
    try {
      localStorage.setItem('orga-reading-mode', String(this.isReadingMode));
    } catch (e) {
      console.warn('ReadingModeToggle: localStorage write failed');
    }
  }

  toggle() {
    this.isReadingMode = !this.isReadingMode;
    this.updateDOM();
    this.saveState();
    this.announceChange();
  }

  updateDOM() {
    if (!this.button) return;

    // Update ARIA state
    this.button.setAttribute('aria-pressed', String(this.isReadingMode));

    // Update body class for CSS targeting
    if (this.isReadingMode) {
      document.body.classList.add('reading-mode');
    } else {
      document.body.classList.remove('reading-mode');
    }

    // Update button text for clarity
    const label = this.button.querySelector('.reading-mode-label');
    if (label) {
      label.textContent = this.isReadingMode ? 'Full Experience' : 'Reading Mode';
    }
  }

  announceChange() {
    if (!this.announcements) return;

    const mode = this.isReadingMode ? 'reading mode' : 'full multimedia experience';
    const message = `Switched to ${mode}`;

    // Clear and announce
    this.announcements.textContent = '';
    setTimeout(() => {
      this.announcements.textContent = message;
    }, 100);
  }
}

// Initialize reading mode manager
new ReadingModeManager();
</script>