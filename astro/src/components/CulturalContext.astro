---
export interface Props {
  title: string;
  context_type: 'historical' | 'cultural' | 'literary' | 'musical' | 'social' | 'political';
  period?: string;
  location?: string;
  significance: 'critical' | 'important' | 'supporting' | 'contextual';
  confidence: 'high' | 'medium' | 'low';
  content: string;
  sources?: string[];
  related_figures?: {
    name: string;
    role: string;
    relationship: string;
  }[];
  cultural_markers?: {
    marker: string;
    explanation: string;
    significance: 'high' | 'medium' | 'low';
  }[];
  historical_parallels?: {
    event: string;
    similarity: string;
    relevance: 'high' | 'medium' | 'low';
  }[];
  references?: string[];
  className?: string;
}

const {
  title,
  context_type,
  period,
  location,
  significance,
  confidence,
  content,
  sources,
  related_figures,
  cultural_markers,
  historical_parallels,
  references,
  className = ''
} = Astro.props;

const contextTypeConfig = {
  historical: {
    label: 'Historical Context',
    icon: '🏛️',
    class: 'context-type--historical'
  },
  cultural: {
    label: 'Cultural Context',
    icon: '🎭',
    class: 'context-type--cultural'
  },
  literary: {
    label: 'Literary Context',
    icon: '📚',
    class: 'context-type--literary'
  },
  musical: {
    label: 'Musical Context',
    icon: '🎵',
    class: 'context-type--musical'
  },
  social: {
    label: 'Social Context',
    icon: '👥',
    class: 'context-type--social'
  },
  political: {
    label: 'Political Context',
    icon: '⚖️',
    class: 'context-type--political'
  }
};

const significanceConfig = {
  critical: {
    label: 'Critical Significance',
    class: 'significance--critical'
  },
  important: {
    label: 'Important',
    class: 'significance--important'
  },
  supporting: {
    label: 'Supporting',
    class: 'significance--supporting'
  },
  contextual: {
    label: 'Contextual',
    class: 'significance--contextual'
  }
};

const confidenceConfig = {
  high: {
    label: 'High Confidence',
    class: 'confidence--high'
  },
  medium: {
    label: 'Medium Confidence',
    class: 'confidence--medium'
  },
  low: {
    label: 'Low Confidence',
    class: 'confidence--low'
  }
};

const contextInfo = contextTypeConfig[context_type];
const significanceInfo = significanceConfig[significance];
const confidenceInfo = confidenceConfig[confidence];
const contextClasses = `cultural-context ${contextInfo.class} ${significanceInfo.class} ${className}`.trim();
const contextId = `context-${title.replace(/\s+/g, '-').toLowerCase()}`;
---

<article class={contextClasses} role="article" aria-labelledby={contextId}>
  <header class="cultural-context__header">
    <div class="cultural-context__title-row">
      <h3 id={contextId} class="cultural-context__title">
        <span class="cultural-context__type-icon" aria-hidden="true">{contextInfo.icon}</span>
        {title}
      </h3>

      <div class="cultural-context__indicators">
        <span class={`context-type-badge ${contextInfo.class}`} aria-label={contextInfo.label}>
          {contextInfo.label}
        </span>
        <span class={`confidence-indicator ${confidenceInfo.class}`} aria-label={confidenceInfo.label}>
          {confidenceInfo.label}
        </span>
      </div>
    </div>

    {(period || location) && (
      <div class="cultural-context__meta">
        {period && (
          <div class="meta-item">
            <strong>Period:</strong>
            <span class="meta-value">{period}</span>
          </div>
        )}
        {location && (
          <div class="meta-item">
            <strong>Location:</strong>
            <span class="meta-value">{location}</span>
          </div>
        )}
        <div class="meta-item">
          <strong>Significance:</strong>
          <span class={`meta-value ${significanceInfo.class}`}>{significanceInfo.label}</span>
        </div>
      </div>
    )}
  </header>

  <div class="cultural-context__content">
    <div class="cultural-context__main-content">
      <div>{content}</div>
    </div>

    {related_figures && related_figures.length > 0 && (
      <section class="cultural-context__section">
        <h4 class="section-title">Key Figures</h4>
        <ul class="figures-list">
          {related_figures.map(figure => (
            <li class="figure-item">
              <div class="figure-name">{figure.name}</div>
              <div class="figure-role">{figure.role}</div>
              <div class="figure-relationship">{figure.relationship}</div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {cultural_markers && cultural_markers.length > 0 && (
      <section class="cultural-context__section">
        <h4 class="section-title">Cultural Markers</h4>
        <ul class="markers-list">
          {cultural_markers.map(marker => (
            <li class={`marker-item marker-significance--${marker.significance}`}>
              <div class="marker-term">{marker.marker}</div>
              <div class="marker-explanation">{marker.explanation}</div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {historical_parallels && historical_parallels.length > 0 && (
      <section class="cultural-context__section">
        <h4 class="section-title">Historical Parallels</h4>
        <ul class="parallels-list">
          {historical_parallels.map(parallel => (
            <li class={`parallel-item parallel-relevance--${parallel.relevance}`}>
              <div class="parallel-event">{parallel.event}</div>
              <div class="parallel-similarity">{parallel.similarity}</div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {sources && sources.length > 0 && (
      <section class="cultural-context__section">
        <h4 class="section-title">Sources</h4>
        <ol class="sources-list">
          {sources.map(source => (
            <li class="source-item">{source}</li>
          ))}
        </ol>
      </section>
    )}

    {references && references.length > 0 && (
      <section class="cultural-context__section">
        <h4 class="section-title">Further Reading</h4>
        <ul class="references-list">
          {references.map(reference => (
            <li class="reference-item">{reference}</li>
          ))}
        </ul>
      </section>
    )}
  </div>
</article>

<style>
  .cultural-context {
    background-color: var(--color-concrete-light);
    border: 1px solid rgba(26, 54, 93, 0.2);
    border-radius: var(--space-sm);
    padding: var(--space-lg);
    margin-bottom: var(--space-lg);
    font-family: var(--font-body);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .cultural-context:hover {
    box-shadow: 0 6px 16px rgba(26, 54, 93, 0.15);
  }

  /* Significance-based border styling */
  .significance--critical {
    border-left: 6px solid var(--color-sage-muted);
  }

  .significance--important {
    border-left: 6px solid var(--color-amber-warm);
  }

  .significance--supporting {
    border-left: 6px solid rgba(214, 158, 46, 0.5);
  }

  .significance--contextual {
    border-left: 6px solid rgba(26, 54, 93, 0.3);
  }

  .cultural-context__header {
    margin-bottom: var(--space-lg);
  }

  .cultural-context__title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .cultural-context__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: var(--line-height-heading);
    color: var(--color-maritime-deep);
    margin: 0;
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .cultural-context__type-icon {
    font-size: 1.5rem;
  }

  .cultural-context__indicators {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: flex-end;
  }

  .context-type-badge,
  .confidence-indicator {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--space-xs);
    border: 1px solid;
    white-space: nowrap;
  }

  /* Context type styles */
  .context-type--historical .context-type-badge {
    background-color: var(--color-maritime-deep);
    border-color: var(--color-maritime-deep);
    color: var(--color-text-inverse);
  }

  .context-type--cultural .context-type-badge,
  .context-type--literary .context-type-badge {
    background-color: var(--color-sage-muted);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .context-type--musical .context-type-badge,
  .context-type--social .context-type-badge {
    background-color: var(--color-amber-warm);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .context-type--political .context-type-badge {
    background-color: rgba(214, 158, 46, 0.3);
    border-color: var(--color-amber-warm);
    color: var(--color-text-primary);
  }

  /* Confidence indicator styles */
  .confidence--high {
    background-color: var(--color-sage-muted);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .confidence--medium {
    background-color: var(--color-amber-warm);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  .confidence--low {
    background-color: rgba(214, 158, 46, 0.3);
    border-color: var(--color-amber-warm);
    color: var(--color-text-primary);
  }

  .cultural-context__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-md);
    padding: var(--space-sm);
    background-color: rgba(26, 54, 93, 0.05);
    border-radius: var(--space-xs);
    font-size: 0.875rem;
  }

  .meta-item {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
  }

  .meta-item strong {
    color: var(--color-maritime-deep);
    font-weight: 600;
    min-width: 5em;
  }

  .meta-value {
    color: var(--color-text-primary);
  }

  .meta-value.significance--critical {
    color: var(--color-sage-muted);
    font-weight: 600;
  }

  .meta-value.significance--important {
    color: var(--color-amber-warm);
    font-weight: 600;
  }

  .cultural-context__content {
    line-height: var(--line-height-body);
  }

  .cultural-context__main-content {
    margin-bottom: var(--space-lg);
    color: var(--color-text-primary);
    font-size: 1rem;
  }

  .cultural-context__main-content p {
    margin-bottom: var(--space-md);
  }

  .cultural-context__main-content p:last-child {
    margin-bottom: 0;
  }

  .cultural-context__section {
    margin-bottom: var(--space-lg);
    padding: var(--space-md);
    background-color: rgba(26, 54, 93, 0.03);
    border-radius: var(--space-xs);
    border: 1px solid rgba(26, 54, 93, 0.1);
  }

  .cultural-context__section:last-child {
    margin-bottom: 0;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-maritime-deep);
    margin: 0 0 var(--space-md) 0;
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid rgba(26, 54, 93, 0.1);
  }

  .figures-list,
  .markers-list,
  .parallels-list,
  .sources-list,
  .references-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .figure-item,
  .marker-item,
  .parallel-item {
    padding: var(--space-sm);
    background-color: var(--color-concrete-light);
    border-radius: var(--space-xs);
    border: 1px solid rgba(26, 54, 93, 0.1);
  }

  .figure-name,
  .marker-term,
  .parallel-event {
    font-weight: 600;
    color: var(--color-maritime-deep);
    margin-bottom: var(--space-xs);
  }

  .figure-role,
  .marker-explanation,
  .parallel-similarity {
    color: var(--color-text-primary);
    font-size: 0.875rem;
    margin-bottom: var(--space-xs);
  }

  .figure-relationship {
    font-style: italic;
    color: rgba(45, 55, 72, 0.8);
    font-size: 0.875rem;
  }

  /* Significance/relevance indicators */
  .marker-significance--high,
  .parallel-relevance--high {
    border-left: 4px solid var(--color-sage-muted);
  }

  .marker-significance--medium,
  .parallel-relevance--medium {
    border-left: 4px solid var(--color-amber-warm);
  }

  .marker-significance--low,
  .parallel-relevance--low {
    border-left: 4px solid rgba(214, 158, 46, 0.5);
  }

  .sources-list {
    counter-reset: source-counter;
  }

  .source-item {
    counter-increment: source-counter;
    padding: var(--space-sm);
    background-color: var(--color-concrete-light);
    border-radius: var(--space-xs);
    font-size: 0.875rem;
    line-height: var(--line-height-body);
    position: relative;
    padding-left: calc(var(--space-sm) + 2em);
  }

  .source-item::before {
    content: counter(source-counter);
    position: absolute;
    left: var(--space-sm);
    top: var(--space-sm);
    font-weight: 600;
    color: var(--color-maritime-deep);
    min-width: 1.5em;
  }

  .reference-item {
    padding: var(--space-sm);
    background-color: rgba(26, 54, 93, 0.05);
    border-radius: var(--space-xs);
    font-size: 0.875rem;
    color: var(--color-text-primary);
    border-left: 3px solid var(--color-amber-warm);
  }

  /* Responsive adjustments */
  @media (max-width: 64rem) {
    .cultural-context {
      padding: var(--space-md);
    }

    .cultural-context__title {
      font-size: 1.25rem;
    }

    .cultural-context__indicators {
      align-items: flex-start;
    }
  }

  @media (max-width: 48rem) {
    .cultural-context__title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .cultural-context__indicators {
      flex-direction: row;
      gap: var(--space-xs);
      flex-wrap: wrap;
    }

    .cultural-context__meta {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .meta-item {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .meta-item strong {
      min-width: auto;
    }

    .figures-list,
    .markers-list,
    .parallels-list {
      gap: var(--space-sm);
    }
  }

  /* Focus management */
  .cultural-context:focus-within {
    outline: 2px solid var(--color-amber-warm);
    outline-offset: 2px;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .cultural-context {
      border-width: 2px;
    }

    .cultural-context__section {
      border-width: 2px;
    }

    .figure-item,
    .marker-item,
    .parallel-item,
    .source-item,
    .reference-item {
      border-width: 2px;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .cultural-context {
      transition: none;
    }
  }
</style>