---
export interface Props {
  status: 'verified' | 'partially_verified' | 'unverified' | 'draft';
  className?: string;
}

const { status, className = '' } = Astro.props;

const statusConfig = {
  verified: {
    text: 'Verified',
    class: 'confidence-badge--verified'
  },
  partially_verified: {
    text: 'Partially Verified',
    class: 'confidence-badge--partial'
  },
  unverified: {
    text: 'Unverified',
    class: 'confidence-badge--unverified'
  },
  draft: {
    text: 'Draft',
    class: 'confidence-badge--draft'
  }
};

const config = statusConfig[status];
const badgeClasses = `confidence-badge ${config.class} ${className}`.trim();
---

<span class={badgeClasses} aria-label={`Investigation status: ${config.text}`}>
  {config.text}
</span>

<style>
  .confidence-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0.25rem;
    border: 2px solid;
    font-family: var(--font-body);
  }

  /* Verified - Sage Muted (Underground Academia) */
  .confidence-badge--verified {
    background-color: var(--color-sage-muted);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  /* Partially Verified - Amber Warm (Underground Academia) */
  .confidence-badge--partial {
    background-color: var(--color-amber-warm);
    border-color: var(--color-maritime-deep);
    color: var(--color-maritime-deep);
  }

  /* Unverified - Muted variant */
  .confidence-badge--unverified {
    background-color: rgba(214, 158, 46, 0.3);
    border-color: var(--color-amber-warm);
    color: var(--color-text-primary);
  }

  /* Draft - Concrete Light (Underground Academia) */
  .confidence-badge--draft {
    background-color: var(--color-concrete-light);
    border-color: var(--color-text-primary);
    color: var(--color-text-primary);
  }
</style>