---
/**
 * Interactive Evidence Gallery Component
 * Professional investigation evidence presentation with annotation support
 */

interface Evidence {
  id: string;
  type: 'image' | 'document' | 'video' | 'audio' | 'data';
  title: string;
  description?: string;
  url: string;
  thumbnail?: string;
  metadata?: {
    source?: string;
    date?: string;
    location?: string;
    significance?: 'high' | 'medium' | 'low';
    verification?: 'verified' | 'partial' | 'unverified' | 'disputed';
  };
  annotations?: Array<{
    id: string;
    x: number;
    y: number;
    title: string;
    description: string;
    category: 'person' | 'location' | 'object' | 'text' | 'anomaly';
  }>;
  tags?: string[];
}

interface Props {
  title: string;
  description?: string;
  evidence: Evidence[];
  layout?: 'grid' | 'timeline' | 'masonry';
  allowAnnotations?: boolean;
  showMetadata?: boolean;
}

const {
  title,
  description,
  evidence,
  layout = 'grid',
  allowAnnotations = true,
  showMetadata = true
} = Astro.props;
---

<section class="evidence-gallery" data-layout={layout}>
  <!-- Gallery Header -->
  <header class="gallery-header">
    <div class="header-content">
      <h2 class="gallery-title">{title}</h2>
      {description && (
        <p class="gallery-description">{description}</p>
      )}
    </div>

    <div class="gallery-controls">
      <div class="layout-controls">
        <button class="layout-btn" data-layout="grid" aria-label="Grid view">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
          </svg>
        </button>
        <button class="layout-btn" data-layout="timeline" aria-label="Timeline view">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="2" x2="12" y2="22"></line>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </button>
        <button class="layout-btn active" data-layout="masonry" aria-label="Masonry view">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="9"></rect>
            <rect x="14" y="3" width="7" height="5"></rect>
            <rect x="14" y="12" width="7" height="9"></rect>
            <rect x="3" y="16" width="7" height="5"></rect>
          </svg>
        </button>
      </div>

      <div class="filter-controls">
        <select class="filter-select" aria-label="Filter by type">
          <option value="all">All Types</option>
          <option value="image">Images</option>
          <option value="document">Documents</option>
          <option value="video">Videos</option>
          <option value="audio">Audio</option>
          <option value="data">Data</option>
        </select>

        <select class="filter-select" aria-label="Filter by verification">
          <option value="all">All Verification Levels</option>
          <option value="verified">Verified</option>
          <option value="partial">Partially Verified</option>
          <option value="unverified">Unverified</option>
          <option value="disputed">Disputed</option>
        </select>
      </div>
    </div>
  </header>

  <!-- Evidence Grid -->
  <div class="evidence-container">
    {evidence.map((item) => (
      <article class="evidence-item"
               data-type={item.type}
               data-verification={item.metadata?.verification}
               data-significance={item.metadata?.significance}
               data-evidence-id={item.id}>

        <!-- Evidence Preview -->
        <div class="evidence-preview">
          {item.type === 'image' && (
            <div class="image-container">
              <img
                src={item.thumbnail || item.url}
                alt={item.title}
                class="evidence-image"
                loading="lazy"
              />
              {allowAnnotations && item.annotations && item.annotations.length > 0 && (
                <div class="annotation-overlay">
                  {item.annotations.map((annotation) => (
                    <button
                      class={`annotation-marker annotation-${annotation.category}`}
                      style={`left: ${annotation.x}%; top: ${annotation.y}%`}
                      data-annotation-id={annotation.id}
                      aria-label={annotation.title}
                    >
                      <span class="marker-dot"></span>
                      <div class="annotation-tooltip">
                        <strong>{annotation.title}</strong>
                        <p>{annotation.description}</p>
                      </div>
                    </button>
                  ))}
                </div>
              )}
            </div>
          )}

          {item.type === 'document' && (
            <div class="document-container">
              <div class="document-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
              </div>
              <div class="document-preview">
                <span class="document-type">PDF</span>
              </div>
            </div>
          )}

          {item.type === 'video' && (
            <div class="video-container">
              <div class="video-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="5,3 19,12 5,21 5,3"></polygon>
                </svg>
              </div>
              <div class="video-duration">02:34</div>
            </div>
          )}

          {item.type === 'audio' && (
            <div class="audio-container">
              <div class="audio-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                  <line x1="12" y1="19" x2="12" y2="23"></line>
                  <line x1="8" y1="23" x2="16" y2="23"></line>
                </svg>
              </div>
              <div class="audio-duration">05:12</div>
            </div>
          )}

          {item.type === 'data' && (
            <div class="data-container">
              <div class="data-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 3v18h18"></path>
                  <path d="m19 9-5 5-4-4-3 3"></path>
                </svg>
              </div>
              <div class="data-type">CSV</div>
            </div>
          )}

          <!-- Verification Badge -->
          {showMetadata && item.metadata?.verification && (
            <div class={`verification-badge verification-${item.metadata.verification}`}>
              <span class="verification-text">
                {item.metadata.verification === 'verified' && 'Verified'}
                {item.metadata.verification === 'partial' && 'Partial'}
                {item.metadata.verification === 'unverified' && 'Unverified'}
                {item.metadata.verification === 'disputed' && 'Disputed'}
              </span>
            </div>
          )}

          <!-- Significance Indicator -->
          {showMetadata && item.metadata?.significance && (
            <div class={`significance-indicator significance-${item.metadata.significance}`}></div>
          )}
        </div>

        <!-- Evidence Details -->
        <div class="evidence-details">
          <h3 class="evidence-title">{item.title}</h3>

          {item.description && (
            <p class="evidence-description">{item.description}</p>
          )}

          {showMetadata && item.metadata && (
            <div class="evidence-metadata">
              {item.metadata.source && (
                <div class="metadata-item">
                  <span class="metadata-label">Source:</span>
                  <span class="metadata-value">{item.metadata.source}</span>
                </div>
              )}

              {item.metadata.date && (
                <div class="metadata-item">
                  <span class="metadata-label">Date:</span>
                  <span class="metadata-value">{item.metadata.date}</span>
                </div>
              )}

              {item.metadata.location && (
                <div class="metadata-item">
                  <span class="metadata-label">Location:</span>
                  <span class="metadata-value">{item.metadata.location}</span>
                </div>
              )}
            </div>
          )}

          {item.tags && item.tags.length > 0 && (
            <div class="evidence-tags">
              {item.tags.map((tag) => (
                <span class="evidence-tag">{tag}</span>
              ))}
            </div>
          )}

          <!-- Actions -->
          <div class="evidence-actions">
            <button class="action-btn primary" data-action="view">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              View
            </button>

            <button class="action-btn secondary" data-action="download">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7,10 12,15 17,10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download
            </button>

            {allowAnnotations && (
              <button class="action-btn secondary" data-action="annotate">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                  <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                </svg>
                Annotate
              </button>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Evidence Modal -->
  <div class="evidence-modal hidden" role="dialog" aria-labelledby="modal-title" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <header class="modal-header">
        <h2 id="modal-title" class="modal-title"></h2>
        <button class="modal-close" aria-label="Close modal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </header>

      <div class="modal-body">
        <div class="modal-media"></div>
        <div class="modal-details"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .evidence-gallery {
    --gallery-primary: var(--folkup-maritime-deep);
    --gallery-accent: var(--folkup-amber-warm);
    --gallery-success: var(--folkup-sage-fresh);
    --gallery-warning: var(--folkup-coral-vibrant);
    --gallery-bg-primary: var(--brand-surface-primary);
    --gallery-bg-elevated: var(--brand-surface-elevated);
    --gallery-text-primary: var(--brand-text-primary);
    --gallery-text-secondary: var(--brand-text-secondary);
    --gallery-border: var(--color-border-subtle);

    background: var(--gallery-bg-primary);
    border-radius: 1rem;
    border: 1px solid var(--gallery-border);
    overflow: hidden;
    margin: 2rem 0;
  }

  /* Gallery Header */
  .gallery-header {
    background: var(--gallery-bg-elevated);
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--gallery-border);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .gallery-title {
    font-family: var(--font-family-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--gallery-text-primary);
    margin: 0 0 0.75rem 0;
  }

  .gallery-description {
    color: var(--gallery-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .gallery-controls {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .layout-controls {
    display: flex;
    gap: 0.5rem;
    background: var(--gallery-bg-primary);
    border: 1px solid var(--gallery-border);
    border-radius: 0.5rem;
    padding: 0.25rem;
  }

  .layout-btn {
    padding: 0.5rem;
    background: transparent;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    color: var(--gallery-text-secondary);
    transition: all 0.2s ease;
  }

  .layout-btn:hover,
  .layout-btn.active {
    background: var(--gallery-primary);
    color: white;
  }

  .layout-btn svg {
    width: 16px;
    height: 16px;
  }

  .filter-controls {
    display: flex;
    gap: 1rem;
  }

  .filter-select {
    background: var(--gallery-bg-primary);
    border: 1px solid var(--gallery-border);
    border-radius: 0.5rem;
    padding: 0.5rem 1rem;
    color: var(--gallery-text-primary);
    font-size: 0.875rem;
    cursor: pointer;
  }

  /* Evidence Container */
  .evidence-container {
    padding: 2rem 2.5rem;
  }

  .evidence-container[data-layout="grid"] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .evidence-container[data-layout="masonry"] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .evidence-container[data-layout="timeline"] {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Evidence Items */
  .evidence-item {
    background: var(--gallery-bg-elevated);
    border: 1px solid var(--gallery-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
  }

  .evidence-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    border-color: var(--gallery-primary);
  }

  /* Evidence Preview */
  .evidence-preview {
    position: relative;
    aspect-ratio: 16/10;
    background: var(--gallery-bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .evidence-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .evidence-item:hover .evidence-image {
    transform: scale(1.05);
  }

  .document-container,
  .video-container,
  .audio-container,
  .data-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: var(--gallery-text-secondary);
  }

  .document-icon,
  .video-icon,
  .audio-icon,
  .data-icon {
    width: 48px;
    height: 48px;
  }

  .document-type,
  .video-duration,
  .audio-duration,
  .data-type {
    background: var(--gallery-primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  /* Annotations */
  .annotation-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .annotation-marker {
    position: absolute;
    background: none;
    border: none;
    cursor: pointer;
    pointer-events: all;
    z-index: 10;
  }

  .marker-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: block;
    border: 2px solid white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .annotation-person .marker-dot { background: var(--gallery-accent); }
  .annotation-location .marker-dot { background: var(--gallery-success); }
  .annotation-object .marker-dot { background: var(--gallery-primary); }
  .annotation-text .marker-dot { background: #8B5CF6; }
  .annotation-anomaly .marker-dot { background: var(--gallery-warning); }

  .annotation-tooltip {
    position: absolute;
    bottom: 120%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gallery-bg-elevated);
    border: 1px solid var(--gallery-border);
    border-radius: 0.5rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    min-width: 180px;
    text-align: left;
  }

  .annotation-marker:hover .annotation-tooltip {
    opacity: 1;
  }

  .annotation-tooltip strong {
    color: var(--gallery-accent);
    display: block;
    margin-bottom: 0.25rem;
  }

  .annotation-tooltip p {
    margin: 0;
    color: var(--gallery-text-secondary);
    white-space: normal;
  }

  /* Verification Badges */
  .verification-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .verification-verified {
    background: var(--gallery-success);
    color: white;
  }

  .verification-partial {
    background: var(--gallery-accent);
    color: white;
  }

  .verification-unverified {
    background: var(--gallery-text-secondary);
    color: white;
  }

  .verification-disputed {
    background: var(--gallery-warning);
    color: white;
  }

  /* Significance Indicators */
  .significance-indicator {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
  }

  .significance-high { background: var(--gallery-warning); }
  .significance-medium { background: var(--gallery-accent); }
  .significance-low { background: var(--gallery-text-secondary); }

  /* Evidence Details */
  .evidence-details {
    padding: 1.5rem;
  }

  .evidence-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--gallery-text-primary);
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
  }

  .evidence-description {
    color: var(--gallery-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  .evidence-metadata {
    margin-bottom: 1rem;
  }

  .metadata-item {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }

  .metadata-label {
    font-weight: 600;
    color: var(--gallery-text-secondary);
    min-width: 60px;
  }

  .metadata-value {
    color: var(--gallery-text-primary);
  }

  /* Evidence Tags */
  .evidence-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .evidence-tag {
    background: var(--gallery-primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
  }

  /* Evidence Actions */
  .evidence-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid;
  }

  .action-btn.primary {
    background: var(--gallery-primary);
    color: white;
    border-color: var(--gallery-primary);
  }

  .action-btn.primary:hover {
    background: var(--gallery-accent);
    border-color: var(--gallery-accent);
  }

  .action-btn.secondary {
    background: transparent;
    color: var(--gallery-text-secondary);
    border-color: var(--gallery-border);
  }

  .action-btn.secondary:hover {
    background: var(--gallery-bg-primary);
    color: var(--gallery-text-primary);
  }

  .action-btn svg {
    width: 14px;
    height: 14px;
  }

  /* Evidence Modal */
  .evidence-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .evidence-modal.hidden {
    display: none;
  }

  .modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: var(--gallery-bg-elevated);
    border: 1px solid var(--gallery-border);
    border-radius: 1rem;
    max-width: 90vw;
    max-height: 90vh;
    width: 100%;
    position: relative;
    z-index: 1001;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--gallery-border);
  }

  .modal-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--gallery-text-primary);
    margin: 0;
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--gallery-text-secondary);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: all 0.2s ease;
  }

  .modal-close:hover {
    background: var(--gallery-bg-primary);
    color: var(--gallery-text-primary);
  }

  .modal-close svg {
    width: 20px;
    height: 20px;
  }

  .modal-body {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  .modal-media {
    flex: 2;
    background: var(--gallery-bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .modal-details {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
    border-left: 1px solid var(--gallery-border);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .gallery-header {
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
      padding: 1.5rem;
    }

    .gallery-controls {
      flex-direction: column;
      gap: 1rem;
    }

    .filter-controls {
      flex-direction: column;
      gap: 0.75rem;
    }

    .evidence-container {
      padding: 1.5rem;
    }

    .evidence-container[data-layout="grid"],
    .evidence-container[data-layout="masonry"] {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .action-btn {
      flex: 1;
      justify-content: center;
    }

    .modal-content {
      max-width: 95vw;
      max-height: 95vh;
    }

    .modal-body {
      flex-direction: column;
    }

    .modal-details {
      border-left: none;
      border-top: 1px solid var(--gallery-border);
    }
  }
</style>

<script>
class EvidenceGallery {
  constructor(container) {
    this.container = container;
    this.layoutBtns = container.querySelectorAll('.layout-btn');
    this.filterSelects = container.querySelectorAll('.filter-select');
    this.evidenceContainer = container.querySelector('.evidence-container');
    this.evidenceItems = container.querySelectorAll('.evidence-item');
    this.actionBtns = container.querySelectorAll('.action-btn');
    this.modal = container.querySelector('.evidence-modal');
    this.modalClose = container.querySelector('.modal-close');
    this.modalBackdrop = container.querySelector('.modal-backdrop');

    this.init();
  }

  init() {
    this.bindEvents();
    this.setInitialLayout();
  }

  bindEvents() {
    // Layout switching
    this.layoutBtns.forEach(btn => {
      btn.addEventListener('click', (e) => this.switchLayout(e.target.dataset.layout));
    });

    // Filtering
    this.filterSelects.forEach(select => {
      select.addEventListener('change', () => this.applyFilters());
    });

    // Evidence actions
    this.actionBtns.forEach(btn => {
      btn.addEventListener('click', (e) => this.handleAction(e));
    });

    // Modal controls
    this.modalClose?.addEventListener('click', () => this.closeModal());
    this.modalBackdrop?.addEventListener('click', () => this.closeModal());

    // Keyboard navigation
    document.addEventListener('keydown', (e) => this.handleKeyboard(e));

    // Annotation interactions
    const annotationMarkers = this.container.querySelectorAll('.annotation-marker');
    annotationMarkers.forEach(marker => {
      marker.addEventListener('click', (e) => this.showAnnotationDetail(e));
    });
  }

  setInitialLayout() {
    const activeBtn = this.container.querySelector('.layout-btn.active');
    if (activeBtn) {
      this.switchLayout(activeBtn.dataset.layout);
    }
  }

  switchLayout(layout) {
    // Update button states
    this.layoutBtns.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.layout === layout);
    });

    // Update container
    this.evidenceContainer.dataset.layout = layout;
    this.container.dataset.layout = layout;

    // Apply layout-specific styling
    this.applyLayoutStyles(layout);
  }

  applyLayoutStyles(layout) {
    switch (layout) {
      case 'timeline':
        this.evidenceItems.forEach((item, index) => {
          item.style.animationDelay = `${index * 0.1}s`;
          item.style.animation = 'slideInFromLeft 0.6s ease-out forwards';
        });
        break;
      case 'masonry':
        this.initMasonryLayout();
        break;
      case 'grid':
      default:
        this.evidenceItems.forEach(item => {
          item.style.animation = '';
        });
        break;
    }
  }

  initMasonryLayout() {
    // Simple masonry-like effect using CSS Grid
    // In a production app, you might want to use a library like Masonry.js
    this.evidenceItems.forEach((item, index) => {
      const height = item.offsetHeight;
      const rowSpan = Math.ceil((height + 10) / 10);
      item.style.gridRowEnd = `span ${rowSpan}`;
    });
  }

  applyFilters() {
    const filters = {};

    this.filterSelects.forEach(select => {
      const value = select.value;
      if (value !== 'all') {
        const filterType = select.getAttribute('aria-label').includes('type') ? 'type' : 'verification';
        filters[filterType] = value;
      }
    });

    this.evidenceItems.forEach(item => {
      let show = true;

      if (filters.type && item.dataset.type !== filters.type) {
        show = false;
      }

      if (filters.verification && item.dataset.verification !== filters.verification) {
        show = false;
      }

      item.style.display = show ? 'block' : 'none';

      if (show) {
        item.style.animation = 'fadeIn 0.4s ease-out';
      }
    });
  }

  handleAction(e) {
    e.preventDefault();
    e.stopPropagation();

    const action = e.currentTarget.dataset.action;
    const evidenceItem = e.currentTarget.closest('.evidence-item');
    const evidenceId = evidenceItem.dataset.evidenceId;

    switch (action) {
      case 'view':
        this.viewEvidence(evidenceId, evidenceItem);
        break;
      case 'download':
        this.downloadEvidence(evidenceId);
        break;
      case 'annotate':
        this.annotateEvidence(evidenceId);
        break;
    }
  }

  viewEvidence(evidenceId, evidenceItem) {
    const title = evidenceItem.querySelector('.evidence-title').textContent;
    const type = evidenceItem.dataset.type;

    // Update modal content
    const modalTitle = this.modal.querySelector('.modal-title');
    const modalMedia = this.modal.querySelector('.modal-media');
    const modalDetails = this.modal.querySelector('.modal-details');

    modalTitle.textContent = title;

    // Clear previous content
    modalMedia.innerHTML = '';
    modalDetails.innerHTML = '';

    // Add media based on type
    if (type === 'image') {
      const img = evidenceItem.querySelector('.evidence-image');
      if (img) {
        const modalImg = img.cloneNode(true);
        modalImg.style.maxWidth = '100%';
        modalImg.style.maxHeight = '100%';
        modalImg.style.objectFit = 'contain';
        modalMedia.appendChild(modalImg);
      }
    } else {
      const placeholder = document.createElement('div');
      placeholder.className = 'media-placeholder';
      placeholder.innerHTML = `
        <div class="placeholder-icon">${this.getTypeIcon(type)}</div>
        <p>View ${type} content</p>
      `;
      modalMedia.appendChild(placeholder);
    }

    // Add details
    const details = evidenceItem.querySelector('.evidence-details').cloneNode(true);
    modalDetails.appendChild(details);

    // Show modal
    this.showModal();
  }

  downloadEvidence(evidenceId) {
    // Implementation would depend on your backend
    console.log(`Downloading evidence: ${evidenceId}`);
  }

  annotateEvidence(evidenceId) {
    // Implementation would open annotation interface
    console.log(`Annotating evidence: ${evidenceId}`);
  }

  showAnnotationDetail(e) {
    e.preventDefault();
    e.stopPropagation();

    const annotationId = e.currentTarget.dataset.annotationId;
    console.log(`Showing annotation detail: ${annotationId}`);

    // Implementation would show annotation details
  }

  getTypeIcon(type) {
    const icons = {
      document: '📄',
      video: '🎥',
      audio: '🎵',
      data: '📊'
    };
    return icons[type] || '📎';
  }

  showModal() {
    this.modal.classList.remove('hidden');
    this.modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Focus trap
    const firstFocusable = this.modal.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    firstFocusable?.focus();
  }

  closeModal() {
    this.modal.classList.add('hidden');
    this.modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  handleKeyboard(e) {
    if (this.modal.classList.contains('hidden')) return;

    switch (e.key) {
      case 'Escape':
        this.closeModal();
        break;
    }
  }
}

// Initialize all evidence galleries
document.addEventListener('DOMContentLoaded', () => {
  const galleries = document.querySelectorAll('.evidence-gallery');
  galleries.forEach(gallery => new EvidenceGallery(gallery));
});

// CSS Animations
const style = document.createElement('style');
style.textContent = `
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes slideInFromLeft {
    from { opacity: 0; transform: translateX(-50px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .media-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: var(--gallery-text-secondary);
  }

  .placeholder-icon {
    font-size: 3rem;
  }
`;
document.head.appendChild(style);
</script>