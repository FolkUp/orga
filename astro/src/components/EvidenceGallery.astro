---
/**
 * Minimal EvidenceGallery component for testing
 */

interface Evidence {
  id: string;
  type: 'image' | 'document' | 'video' | 'audio' | 'data';
  title: string;
  description?: string;
  url: string;
  thumbnail?: string;
  metadata?: {
    verification?: 'verified' | 'partial' | 'unverified' | 'disputed';
  };
}

interface Props {
  title: string;
  description?: string;
  evidence: Evidence[];
  layout?: 'grid' | 'timeline' | 'masonry';
}

const {
  title,
  description,
  evidence,
  layout = 'grid'
} = Astro.props;
---

<!-- Minimal Evidence Gallery -->
<section class="evidence-gallery" data-layout={layout}>
  <header class="gallery-header">
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </header>

  <div class="evidence-grid">
    {evidence.map((item, index) => (
      <div class="evidence-item" data-type={item.type}>
        <h3>{item.title}</h3>
        <p>{item.description || 'No description'}</p>
      </div>
    ))}
  </div>
</section>

<style>
.evidence-gallery {
  background: #0f1b25;
  color: #e8f0f7;
  padding: 2rem;
}

.gallery-header {
  margin-bottom: 2rem;
}

.gallery-header h2 {
  color: #d69e2e;
  margin-bottom: 0.5rem;
}

.evidence-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

.evidence-item {
  background: #2d3748;
  padding: 1rem;
  border: 1px solid #4a5568;
}

.evidence-item h3 {
  color: #d69e2e;
  margin-bottom: 0.5rem;
}
</style>