---
/**
 * ORGA-067: HeroVisualization.astro - Optimized Astro Islands Implementation
 * High-performance hero with delayed activation for optimal Core Web Vitals
 *
 * @component HeroVisualization
 * @performance Delayed activation, progressive enhancement, text-first rendering
 * @expert Johnny (frontend performance optimization)
 */

export interface Props {
  heroData?: any;
  visualizationType?: 'seismograph' | 'timeline' | 'static';
  className?: string;
  id?: string;
  enableAnimation?: boolean;
  delayActivation?: number; // milliseconds
  fallbackMode?: boolean;
}

const {
  heroData = null,
  visualizationType = 'static',
  className = '',
  id = 'hero-visualization',
  enableAnimation = true,
  delayActivation = 2000, // 2s delay for Core Web Vitals
  fallbackMode = false
} = Astro.props;

// Server-side processing for hero data
const hasValidData = heroData && (heroData.title || heroData.narrative);
const isInteractiveType = visualizationType !== 'static' && enableAnimation && !fallbackMode;
---

<div
  id={id}
  class={`hero-visualization-wrapper ${className}`}
  data-component="HeroVisualization"
  data-has-data={hasValidData}
  data-type={visualizationType}
  data-interactive={isInteractiveType}
>
  {hasValidData ? (
    <!-- Hero Section with Progressive Enhancement -->
    <section class="hero-visualization-container">
      <!-- Text-first content - rendered server-side immediately -->
      <div class="hero-text-content">
        {heroData.title && (
          <h1 class="hero-title">{heroData.title}</h1>
        )}

        {heroData.subtitle && (
          <p class="hero-subtitle">{heroData.subtitle}</p>
        )}

        {heroData.narrative && (
          <div class="hero-narrative">
            <p>{heroData.narrative}</p>
          </div>
        )}

        {heroData.metadata && (
          <div class="hero-metadata">
            <div class="hero-meta-grid">
              {heroData.metadata.location && (
                <div class="hero-meta-item">
                  <span class="hero-meta-label">Location:</span>
                  <span class="hero-meta-value">{heroData.metadata.location}</span>
                </div>
              )}

              {heroData.metadata.period && (
                <div class="hero-meta-item">
                  <span class="hero-meta-label">Period:</span>
                  <span class="hero-meta-value">{heroData.metadata.period}</span>
                </div>
              )}

              {heroData.metadata.status && (
                <div class="hero-meta-item">
                  <span class="hero-meta-label">Status:</span>
                  <span class="hero-meta-value">{heroData.metadata.status}</span>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      {/* Visual layer - loaded after delay for optimal LCP */}
      {isInteractiveType && (
        <div
          id={`${id}-visual`}
          class="hero-visual-layer"
          data-hero-visual
          data-delay={delayActivation}
        >
          <!-- Visualization will be loaded here after delay -->
        </div>
      )}

      {/* Static background patterns - immediate but low priority */}
      <div class="hero-background-layer" aria-hidden="true">
        <div class="hero-background-pattern hero-background-pattern--1"></div>
        <div class="hero-background-pattern hero-background-pattern--2"></div>
        <div class="hero-background-pattern hero-background-pattern--3"></div>
      </div>
    </section>
  ) : (
    <!-- No-data fallback -->
    <section class="hero-no-data">
      <div class="hero-no-data__content">
        <h1>Underground Academia</h1>
        <p>Cultural Seismography Platform</p>
        <p class="hero-no-data__subtitle">Content is currently being prepared.</p>
      </div>
    </section>
  )}

  <!-- Progressive Enhancement Script with Delay -->
  {isInteractiveType && hasValidData && (
    <script type="module" define:vars={{ delayActivation, visualizationType, heroData }}>
      // Delayed hero visualization loading
      const enhanceHeroVisualization = async () => {
        const container = document.getElementById(`${id}-visual`);
        if (!container) return;

        // Wait for specified delay to optimize Core Web Vitals
        await new Promise(resolve => setTimeout(resolve, delayActivation));

        // Check if page is still visible (user hasn't navigated away)
        if (document.visibilityState === 'hidden') {
          console.debug('Page hidden, skipping hero enhancement');
          return;
        }

        try {
          // Dynamic import based on visualization type
          let visualizer;

          if (visualizationType === 'seismograph') {
            const { SeismographVisualizer } = await import('../utils/seismograph-visualizer.js');
            visualizer = new SeismographVisualizer({
              container,
              data: heroData,
              options: {
                enableAnimation: true,
                enableInteraction: true,
                performance: 'balanced'
              }
            });
          } else if (visualizationType === 'timeline') {
            const { TimelineVisualizer } = await import('../utils/timeline-visualizer.js');
            visualizer = new TimelineVisualizer({
              container,
              data: heroData,
              options: {
                enableAnimation: true,
                enableNavigation: true,
                performance: 'balanced'
              }
            });
          }

          if (visualizer) {
            await visualizer.initialize();

            // Mark as enhanced
            container.setAttribute('data-enhanced', 'true');

            // Performance mark
            if (performance.mark) {
              performance.mark('hero-visualization-loaded');
            }

            console.debug('✅ Hero visualization enhanced');
          }
        } catch (error) {
          console.warn('Hero visualization enhancement failed, using static fallback:', error);
          // Remove visual layer to avoid broken state
          container.remove();
        }
      };

      // Initialize after DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', enhanceHeroVisualization);
      } else {
        enhanceHeroVisualization();
      }
    </script>
  )}
</div>

<style>
  .hero-visualization-wrapper {
    position: relative;
    width: 100%;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg,
      var(--color-surface-primary, #fefcf6) 0%,
      var(--color-surface-secondary, #f8f6f0) 100%
    );
    overflow: hidden;
  }

  .hero-visualization-container {
    position: relative;
    width: 100%;
    max-width: var(--container-max-width, 1200px);
    padding: var(--spacing-xl, 32px);
    text-align: center;
    z-index: 2;
  }

  /* Text content - immediate rendering */
  .hero-text-content {
    position: relative;
    z-index: 3;
  }

  .hero-title {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--color-text-primary, #7d4450);
    margin: 0 0 var(--spacing-md, 16px) 0;
    line-height: 1.2;
    text-shadow: 0 2px 4px rgba(125, 68, 80, 0.1);
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 3vw, 1.5rem);
    color: var(--color-text-secondary, #5a5a5a);
    margin: 0 0 var(--spacing-lg, 24px) 0;
    font-weight: 400;
  }

  .hero-narrative {
    max-width: 600px;
    margin: 0 auto var(--spacing-lg, 24px) auto;
  }

  .hero-narrative p {
    font-size: var(--text-lg, 18px);
    line-height: 1.6;
    color: var(--color-text-primary, #7d4450);
    margin: 0;
  }

  /* Metadata grid */
  .hero-metadata {
    margin-top: var(--spacing-xl, 32px);
  }

  .hero-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md, 16px);
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-meta-item {
    background: rgba(131, 158, 117, 0.1);
    padding: var(--spacing-md, 16px);
    border-radius: 6px;
    border: 1px solid var(--color-border-secondary, #e0e0e0);
  }

  .hero-meta-label {
    display: block;
    font-weight: 600;
    color: var(--color-text-secondary, #5a5a5a);
    font-size: var(--text-sm, 14px);
    margin-bottom: var(--spacing-xs, 4px);
  }

  .hero-meta-value {
    display: block;
    color: var(--color-text-primary, #7d4450);
    font-weight: 700;
    font-size: var(--text-base, 16px);
  }

  /* Visual layer - delayed loading */
  .hero-visual-layer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none; /* Until enhanced */
    z-index: 1;
  }

  .hero-visual-layer[data-enhanced="true"] {
    pointer-events: auto;
  }

  /* Background patterns - immediate but subtle */
  .hero-background-layer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
    opacity: 0.05;
  }

  .hero-background-pattern {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-primary, #e8ad4a) 0%, transparent 70%);
  }

  .hero-background-pattern--1 {
    top: 20%;
    left: 10%;
    width: 200px;
    height: 200px;
    animation: heroFloat 8s ease-in-out infinite;
  }

  .hero-background-pattern--2 {
    top: 60%;
    right: 15%;
    width: 150px;
    height: 150px;
    animation: heroFloat 12s ease-in-out infinite reverse;
  }

  .hero-background-pattern--3 {
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    animation: heroFloat 10s ease-in-out infinite;
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }

  /* No-data fallback styling */
  .hero-no-data {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface-secondary, #f8f6f0);
    text-align: center;
    padding: var(--spacing-xl, 32px);
  }

  .hero-no-data__content h1 {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: var(--color-text-primary, #7d4450);
    margin: 0 0 var(--spacing-md, 16px) 0;
  }

  .hero-no-data__content p {
    font-size: var(--text-lg, 18px);
    color: var(--color-text-secondary, #5a5a5a);
    margin: 0 0 var(--spacing-sm, 8px) 0;
  }

  .hero-no-data__subtitle {
    font-style: italic;
    font-size: var(--text-base, 16px) !important;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .hero-visualization-wrapper {
      min-height: 50vh;
    }

    .hero-visualization-container {
      padding: var(--spacing-lg, 24px);
    }

    .hero-meta-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm, 8px);
    }

    .hero-background-pattern {
      opacity: 0.5;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .hero-background-pattern {
      animation: none;
    }
  }

  /* High contrast mode */
  @media (prefers-contrast: high) {
    .hero-title {
      text-shadow: none;
    }

    .hero-meta-item {
      border-width: 2px;
    }
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    .hero-visualization-wrapper {
      background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
    }

    .hero-background-layer {
      opacity: 0.02;
    }
  }
</style>