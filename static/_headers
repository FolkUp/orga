# Security Headers for ORGA - Production Excellence
/*
  # Content Security Policy - ProPublica-level security
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://polyfill.io; connect-src 'self' https:; frame-src 'self' https://www.youtube.com https://bandcamp.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

  # Security Headers Suite
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Performance Headers
  Cache-Control: public, max-age=31536000, immutable

  # GDPR/Privacy Compliance
  Set-Cookie: SameSite=Strict; Secure; HttpOnly

# CSS/JS Assets - Extended Caching
/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/javascript; charset=utf-8

# Fonts - Optimized Caching
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Images - WebP Optimization
/images/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

# HTML Pages - Fresh Content
/*.html
  Cache-Control: public, max-age=3600
  Vary: Accept-Encoding, Accept-Language