---
/**
 * Evidence Gallery Astro Component - ORGA-066 Implementation
 * Main entry point for the multimedia scholarship archive
 *
 * @component EvidenceGallery
 * @integration Astro Islands with Svelte components
 * @accessibility WCAG 2.1 AA compliant
 * @performance SSG with hydrated interactivity
 */

// Component imports - using client-side hydration for interactivity
export interface Props {
  selectedAct?: string;
  selectedType?: string;
  sortBy?: string;
  accessibilityMode?: boolean;
  offlineMode?: boolean;
  title?: string;
  description?: string;
}

// Props with defaults
const {
  selectedAct = 'all',
  selectedType = 'all',
  sortBy = 'chronological',
  accessibilityMode = false,
  offlineMode = false,
  title = 'Evidence Gallery — Multimedia Scholarship Archive',
  description = 'Comprehensive academic evidence archive supporting underground scholarship investigation with banking-level accessibility standards and Underground Academia visual aesthetics.'
} = Astro.props;

// Meta information for SEO and accessibility
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = `${title} | ORGA Underground Academia`;
const pageDescription = description;
---

<!DOCTYPE html>
<html lang="ru" class="evidence-gallery-page">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:site_name" content="ORGA Underground Academia" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={pageTitle} />
  <meta property="twitter:description" content={pageDescription} />

  <!-- Accessibility and UX meta -->
  <meta name="theme-color" content="#8B4513" />
  <meta name="color-scheme" content="light dark" />

  <!-- Preload critical resources -->
  <link rel="preload" href="/fonts/PlayfairDisplay-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/SourceSans3-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin />

  <title>{pageTitle}</title>

  <!-- Critical CSS for performance -->
  <style>
    /* Critical loading styles */
    .evidence-gallery-loading {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #FEFCF6;
      font-family: 'Source Sans 3', sans-serif;
    }

    .loading-content {
      text-align: center;
      padding: 2rem;
      border: 2px solid #8B4513;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.9);
    }

    .loading-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: #2F4F4F;
      margin: 0 0 1rem 0;
    }

    .loading-message {
      color: #6B4423;
      margin: 0 0 1rem 0;
    }

    .loading-spinner {
      width: 40px;
      height: 40px;
      border: 3px solid rgba(139, 69, 19, 0.2);
      border-top: 3px solid #8B4513;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Hide main content until hydrated */
    .evidence-gallery-container[data-hydrated="false"] {
      display: none;
    }
  </style>
</head>

<body>
  <!-- Skip navigation for accessibility -->
  <a href="#main-content" class="skip-link">
    Перейти к основному содержимому
  </a>

  <!-- Page header -->
  <header class="page-header" role="banner">
    <div class="header-content">
      <h1 class="page-title">
        <span class="title-main">{title}</span>
        <span class="title-subtitle">ORGA Underground Academia</span>
      </h1>

      <nav class="header-navigation" aria-label="Основная навигация">
        <ul class="nav-list">
          <li><a href="/" class="nav-link">Главная</a></li>
          <li><a href="/timeline" class="nav-link">Временная линия</a></li>
          <li><a href="/evidence" class="nav-link current" aria-current="page">Архив доказательств</a></li>
          <li><a href="/methodology" class="nav-link">Методология</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Loading state (shown before hydration) -->
  <div class="evidence-gallery-loading" id="loading-state">
    <div class="loading-content">
      <h2 class="loading-title">Загрузка архива</h2>
      <p class="loading-message">Подготовка академических документов...</p>
      <div class="loading-spinner" aria-label="Загрузка" role="progressbar"></div>
    </div>
  </div>

  <!-- Main gallery container -->
  <main id="main-content" class="evidence-gallery-main">
    <!-- Gallery component with client-side hydration -->
    <div
      id="evidence-gallery-container"
      class="evidence-gallery-container"
      data-hydrated="false"
    >
      <!-- Server-rendered fallback content -->
      <noscript>
        <div class="noscript-fallback">
          <h2>JavaScript Required</h2>
          <p>
            Для полноценной работы архива доказательств требуется JavaScript.
            Пожалуйста, включите JavaScript в вашем браузере.
          </p>
          <p>
            Архив содержит интерактивную галерею академических документов
            с полной поддержкой доступности и клавиатурной навигации.
          </p>
        </div>
      </noscript>

      <!-- Hydration target -->
      <div id="evidence-gallery-mount"></div>
    </div>
  </main>

  <!-- Page footer -->
  <footer class="page-footer" role="contentinfo">
    <div class="footer-content">
      <div class="footer-section">
        <h3 class="footer-title">ORGA Underground Academia</h3>
        <p class="footer-description">
          Академическое исследование культурных феноменов с применением
          банковского уровня стандартов доступности и научной строгости.
        </p>
      </div>

      <div class="footer-section">
        <h4 class="footer-subtitle">Соответствие стандартам</h4>
        <ul class="compliance-list">
          <li>WCAG 2.1 AA</li>
          <li>EU AI Act Art. 50</li>
          <li>Academic Citation Standards</li>
          <li>Underground Academia Protocol</li>
        </ul>
      </div>

      <div class="footer-section">
        <h4 class="footer-subtitle">Техническая информация</h4>
        <ul class="technical-list">
          <li>Component: ORGA-066</li>
          <li>Version: Evidence Gallery v1.0</li>
          <li>Framework: Astro + Svelte Islands</li>
          <li>Accessibility: Banking-level compliance</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © 2026 ORGA Underground Academia.
        Все права защищены. Академическое использование разрешено.
      </p>
    </div>
  </footer>

  <!-- Hydration script -->
  <script type="module">
    import EvidenceGalleryContainer from './components/evidence/EvidenceGalleryContainer.svelte';

    // Initialize evidence gallery after DOM load
    document.addEventListener('DOMContentLoaded', function() {
      const mountPoint = document.getElementById('evidence-gallery-mount');
      const container = document.getElementById('evidence-gallery-container');
      const loadingState = document.getElementById('loading-state');

      if (mountPoint) {
        try {
          // Initialize Svelte component
          const gallery = new EvidenceGalleryContainer({
            target: mountPoint,
            props: {
              selectedAct: '{selectedAct}',
              selectedType: '{selectedType}',
              sortBy: '{sortBy}',
              accessibilityMode: {accessibilityMode},
              offlineMode: {offlineMode}
            }
          });

          // Handle hydration complete
          gallery.$on('hydration-complete', () => {
            if (container) {
              container.setAttribute('data-hydrated', 'true');
            }
            if (loadingState) {
              loadingState.style.display = 'none';
            }
          });

          // Handle accessibility announcements
          gallery.$on('accessibility-announce', (event) => {
            const { message, priority = 'polite' } = event.detail;
            announceToScreenReader(message, priority);
          });

          // Mark as hydrated
          setTimeout(() => {
            if (container) {
              container.setAttribute('data-hydrated', 'true');
            }
            if (loadingState) {
              loadingState.style.display = 'none';
            }
          }, 100);

        } catch (error) {
          console.error('Evidence Gallery hydration failed:', error);

          // Show fallback error message
          if (mountPoint) {
            mountPoint.innerHTML = `
              <div class="hydration-error">
                <h2>Ошибка загрузки</h2>
                <p>Произошла ошибка при инициализации архива доказательств.</p>
                <p>Пожалуйста, обновите страницу или попробуйте позже.</p>
                <button onclick="window.location.reload()">Обновить страницу</button>
              </div>
            `;
          }

          if (loadingState) {
            loadingState.style.display = 'none';
          }
        }
      }
    });

    // Screen reader announcement function
    function announceToScreenReader(message, priority = 'polite') {
      const announcement = document.createElement('div');
      announcement.setAttribute('aria-live', priority);
      announcement.setAttribute('aria-atomic', 'true');
      announcement.className = 'sr-only';
      announcement.textContent = message;

      document.body.appendChild(announcement);

      // Clean up after announcement
      setTimeout(() => {
        if (announcement.parentNode) {
          announcement.parentNode.removeChild(announcement);
        }
      }, 5000);
    }

    // Progressive enhancement for offline support
    if ('serviceWorker' in navigator && {offlineMode}) {
      navigator.serviceWorker.register('/evidence-gallery-sw.js')
        .then(registration => {
          console.log('Evidence Gallery SW registered:', registration);
        })
        .catch(error => {
          console.log('Evidence Gallery SW registration failed:', error);
        });
    }
  </script>

  <!-- Fallback CSS for non-hydrated state -->
  <style>
    /* Page structure styles */
    .evidence-gallery-page {
      font-family: 'Source Sans 3', sans-serif;
      background: #FEFCF6;
      color: #2F4F4F;
    }

    /* Skip link */
    .skip-link {
      position: absolute;
      top: -40px;
      left: 6px;
      background: #2F4F4F;
      color: #FEFCF6;
      padding: 8px;
      border-radius: 4px;
      text-decoration: none;
      z-index: 2000;
    }

    .skip-link:focus {
      top: 6px;
      outline: 2px solid #FFBF00;
    }

    /* Page header */
    .page-header {
      background: linear-gradient(135deg, #8B4513 0%, #6B4423 100%);
      color: #FEFCF6;
      padding: 2rem 1rem;
      border-bottom: 3px solid #6B4423;
    }

    .header-content {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }

    .page-title {
      margin: 0;
    }

    .title-main {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .title-subtitle {
      display: block;
      font-family: 'Courier New', monospace;
      font-size: 0.875rem;
      opacity: 0.9;
      margin-top: 0.5rem;
      letter-spacing: 1px;
    }

    /* Header navigation */
    .header-navigation {
      flex-shrink: 0;
    }

    .nav-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      gap: 1.5rem;
    }

    .nav-link {
      color: #FEFCF6;
      text-decoration: none;
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 600;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      transition: all 0.2s ease;
    }

    .nav-link:hover,
    .nav-link:focus {
      background: rgba(255, 255, 255, 0.1);
      outline: 1px solid #FFBF00;
    }

    .nav-link.current {
      background: #FFBF00;
      color: #6B4423;
    }

    /* Main content area */
    .evidence-gallery-main {
      min-height: 70vh;
      padding: 2rem 1rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* Fallback styles */
    .noscript-fallback,
    .hydration-error {
      text-align: center;
      padding: 3rem 2rem;
      background: rgba(255, 255, 255, 0.9);
      border: 2px solid #8B4513;
      border-radius: 8px;
      max-width: 600px;
      margin: 2rem auto;
    }

    .noscript-fallback h2,
    .hydration-error h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      color: #2F4F4F;
      margin: 0 0 1rem 0;
    }

    .hydration-error button {
      background: #8B4513;
      color: #FEFCF6;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1rem;
      transition: background-color 0.2s ease;
    }

    .hydration-error button:hover,
    .hydration-error button:focus {
      background: #6B4423;
      outline: 1px solid #FFBF00;
    }

    /* Page footer */
    .page-footer {
      background: linear-gradient(135deg, rgba(139, 69, 19, 0.05) 0%, rgba(139, 69, 19, 0.1) 100%);
      border-top: 1px solid rgba(139, 69, 19, 0.2);
      padding: 2rem 1rem 1rem 1rem;
      margin-top: 4rem;
    }

    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .footer-section {
      margin-bottom: 1rem;
    }

    .footer-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #2F4F4F;
      margin: 0 0 1rem 0;
    }

    .footer-subtitle {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      color: #6B4423;
      margin: 0 0 0.75rem 0;
    }

    .footer-description {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9rem;
      color: #8B4513;
      line-height: 1.6;
      margin: 0;
    }

    .compliance-list,
    .technical-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .compliance-list li,
    .technical-list li {
      font-family: 'Courier New', monospace;
      font-size: 0.8rem;
      color: #6B4423;
      padding: 0.25rem 0;
      border-bottom: 1px solid rgba(139, 69, 19, 0.1);
    }

    .footer-bottom {
      max-width: 1200px;
      margin: 2rem auto 0 auto;
      padding-top: 1rem;
      border-top: 1px solid rgba(139, 69, 19, 0.2);
      text-align: center;
    }

    .copyright {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.8rem;
      color: #8B4513;
      margin: 0;
    }

    /* Screen reader only class */
    .sr-only {
      position: absolute;
      left: -10000px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    /* Responsive design */
    @media (max-width: 768px) {
      .header-content {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
      }

      .title-main {
        font-size: 1.75rem;
      }

      .nav-list {
        flex-direction: column;
        gap: 0.75rem;
      }

      .evidence-gallery-main {
        padding: 1rem 0.5rem;
      }

      .footer-content {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        text-align: center;
      }
    }

    /* High contrast mode */
    @media (prefers-contrast: high) {
      .evidence-gallery-page {
        background: #FFFFFF;
        color: #000000;
      }

      .page-header {
        background: #000000;
        color: #FFFFFF;
      }

      .nav-link.current {
        background: #FFFF00;
        color: #000000;
      }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .loading-spinner {
        animation: none;
      }

      .nav-link,
      .hydration-error button {
        transition: none;
      }
    }
  </style>
</body>
</html>